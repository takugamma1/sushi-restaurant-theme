{%- doc -%}
  Restaurant product modal component - Single page design.
  - Home page: Preview only with "See full menu" button
  - Menu page: Full ordering with add-ons carousel and note

  @param {object} addons_collection - Collection for add-ons products
  @param {string} addons_title - Title for the add-ons section
  @param {string} menu_page_url - URL for the full menu page
{%- enddoc -%}

{%- liquid
  assign is_menu_page = false
  if template.suffix == 'menu' or request.path contains '/pages/menu'
    assign is_menu_page = true
  endif

  assign menu_page_url = menu_page_url | default: '/pages/меню-суши-манго'
  assign addons_title = addons_title | default: 'Добави към поръчката'
-%}

<div class="rm-modal" id="rm-product-modal" aria-hidden="true">
  <div class="rm-modal__backdrop" data-close-modal></div>
  <div class="rm-modal__container">
    <button class="rm-modal__close" type="button" data-close-modal aria-label="Close">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    {%- comment -%} Modal content wrapper — media + order panel {%- endcomment -%}
    <div class="rm-modal__content">

      {%- comment -%} Media side {%- endcomment -%}
      <div class="rm-modal__media">
        <span class="rm-modal__handle" aria-hidden="true"></span>
        <img src="" alt="" id="rm-modal-image" class="rm-modal__media-img">
        <span class="rm-modal__media-tag"><span class="rm-modal__media-diamond">◇</span> Mango Sushi Bar</span>
      </div>

      {%- comment -%} Order panel {%- endcomment -%}
      <div class="rm-modal__panel">
        <div class="rm-modal__panel-scroll">
          <div class="rm-modal__head">
            <h3 class="rm-modal__product-title" id="rm-modal-title"></h3>
            <div class="rm-modal__price" id="rm-modal-price"></div>
          </div>
          <p class="rm-modal__product-desc" id="rm-modal-desc"></p>

          {%- if is_menu_page -%}
            <div class="rm-modal__divider"><span class="rm-modal__divider-d">◇</span></div>

            {%- comment -%} Quantity {%- endcomment -%}
            <div class="rm-modal__qty-row">
              <span class="rm-modal__qty-label">Количество</span>
              <div class="rm-modal__qty">
                <button type="button" class="rm-modal__qty-btn" data-qty-minus aria-label="Намали">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                </button>
                <span class="rm-modal__qty-val" id="rm-modal-qty">1</span>
                <button type="button" class="rm-modal__qty-btn" data-qty-plus aria-label="Увеличи">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                </button>
              </div>
            </div>

            {%- comment -%} Add-ons section with carousel {%- endcomment -%}
            {%- if addons_collection != blank and addons_collection.products.size > 0 -%}
              <div class="rm-modal__addons-section">
                <h4 class="rm-modal__addons-title">{{ addons_title }} <span class="rm-modal__optional">(по желание)</span></h4>

                <div class="rm-modal__carousel-wrapper">
                  <button type="button" class="rm-modal__carousel-btn rm-modal__carousel-btn--prev" data-carousel-prev aria-label="Previous">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polyline points="15 18 9 12 15 6"></polyline>
                    </svg>
                  </button>

                  <div class="rm-modal__carousel" id="rm-modal-carousel">
                    <div class="rm-modal__carousel-track" id="rm-modal-carousel-track">
                      {%- for product in addons_collection.products limit: 20 -%}
                        <label class="rm-modal__addon-card">
                          <input
                            type="checkbox"
                            name="addon[]"
                            value="{{ product.selected_or_first_available_variant.id }}"
                            data-price="{{ product.price }}"
                            data-title="{{ product.title | escape }}"
                          >
                          <span class="rm-modal__addon-card-inner">
                            <span class="rm-modal__addon-image">
                              {%- if product.featured_image != blank -%}
                                <img
                                  src="{{ product.featured_image | image_url: width: 300, height: 300, crop: 'center' }}"
                                  alt="{{ product.featured_image.alt | escape }}"
                                  loading="lazy"
                                >
                              {%- else -%}
                                <span class="rm-modal__addon-placeholder"></span>
                              {%- endif -%}
                            </span>
                            <span class="rm-modal__addon-details">
                              <span class="rm-modal__addon-name">{{ product.title }}</span>
                              <span class="rm-modal__addon-price">+{{ product.price | money }}</span>
                            </span>
                            <span class="rm-modal__addon-check">
                              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                <polyline points="20 6 9 17 4 12"></polyline>
                              </svg>
                            </span>
                          </span>
                        </label>
                      {%- endfor -%}
                    </div>
                  </div>

                  <button type="button" class="rm-modal__carousel-btn rm-modal__carousel-btn--next" data-carousel-next aria-label="Next">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polyline points="9 18 15 12 9 6"></polyline>
                    </svg>
                  </button>
                </div>
              </div>
            {%- endif -%}

            {%- comment -%} Order note {%- endcomment -%}
            <div class="rm-modal__note-section">
              <h4 class="rm-modal__note-label">Бележка към поръчката <span class="rm-modal__optional">(по желание)</span></h4>
              <textarea
                class="rm-modal__note"
                id="rm-modal-note"
                placeholder="Напр: Без лук, допълнително сусам, алергии..."
                rows="2"
              ></textarea>
            </div>
          {%- endif -%}
        </div>

        {%- if is_menu_page -%}
          {%- comment -%} Sticky footer: total + add button {%- endcomment -%}
          <div class="rm-modal__footer">
            <div class="rm-modal__total">
              <span class="rm-modal__total-label">Общо</span>
              <span class="rm-modal__total-price" id="rm-modal-total">{{ 0 | money }}</span>
            </div>
            <button type="button" class="rm-modal__btn rm-modal__btn--add" data-add-to-cart>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="9" cy="21" r="1"></circle>
                <circle cx="20" cy="21" r="1"></circle>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
              </svg>
              Добави
            </button>
          </div>
        {%- else -%}
          {%- comment -%} Home page: Preview only {%- endcomment -%}
          <div class="rm-modal__footer rm-modal__footer--preview">
            <a href="{{ menu_page_url }}" class="rm-modal__btn rm-modal__btn--full">
              Виж пълното меню
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Loading state {%- endcomment -%}
    <div class="rm-modal__loading" id="rm-modal-loading" style="display: none;">
      <div class="rm-modal__spinner"></div>
      <span>Добавяне...</span>
    </div>

    {%- comment -%} Success state {%- endcomment -%}
    <div class="rm-modal__success" id="rm-modal-success" style="display: none;">
      <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
        <polyline points="22 4 12 14.01 9 11.01"></polyline>
      </svg>
      <span>Добавено в кошницата!</span>
    </div>
  </div>
</div>

<script>
class RestaurantProductModal {
  constructor() {
    this.modal = document.getElementById('rm-product-modal');
    if (!this.modal) return;

    this.isMenuPage = {{ is_menu_page | json }};
    this.selectedProduct = null;
    this.basePrice = 0;
    this.quantity = 1;
    this.carouselPosition = 0;
    this.moneyFormat = {{ shop.money_format | json }};

    this.bindEvents();
  }

  // Format an amount in cents using the shop's money format (respects store currency).
  formatMoney(cents) {
    cents = parseInt(cents, 10) || 0;
    const value = (cents / 100).toFixed(2);
    // Build the placeholder via concatenation so the Liquid parser never sees
    // a literal double-brace pair inside this script.
    const ph = '{' + '{amount}' + '}';
    const format = this.moneyFormat || ph;
    const re = (name) => new RegExp('\\{\\{\\s*' + name + '\\s*\\}\\}', 'g');
    return format
      .replace(re('amount_no_decimals_with_comma_separator'), Math.round(cents / 100).toString())
      .replace(re('amount_no_decimals'), Math.round(cents / 100).toString())
      .replace(re('amount_with_comma_separator'), value.replace('.', ','))
      .replace(re('amount'), value);
  }

  bindEvents() {
    // Close modal
    this.modal.querySelectorAll('[data-close-modal]').forEach(btn => {
      btn.addEventListener('click', () => this.close());
    });

    // Close on escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && this.modal.getAttribute('aria-hidden') === 'false') {
        this.close();
      }
    });

    if (this.isMenuPage) {
      // Add to cart
      const addBtn = this.modal.querySelector('[data-add-to-cart]');
      if (addBtn) addBtn.addEventListener('click', () => this.addToCart());

      // Quantity stepper
      const minus = this.modal.querySelector('[data-qty-minus]');
      const plus = this.modal.querySelector('[data-qty-plus]');
      if (minus) minus.addEventListener('click', () => this.setQuantity(this.quantity - 1));
      if (plus) plus.addEventListener('click', () => this.setQuantity(this.quantity + 1));

      // Update total on addon change
      this.modal.querySelectorAll('input[type="checkbox"]').forEach(input => {
        input.addEventListener('change', () => this.updateTotal());
      });

      // Carousel navigation
      const prevBtn = this.modal.querySelector('[data-carousel-prev]');
      const nextBtn = this.modal.querySelector('[data-carousel-next]');
      if (prevBtn) prevBtn.addEventListener('click', () => this.carouselPrev());
      if (nextBtn) nextBtn.addEventListener('click', () => this.carouselNext());

      // Touch swipe for carousel
      this.initCarouselTouch();
    }
  }

  initCarouselTouch() {
    const carousel = document.getElementById('rm-modal-carousel');
    if (!carousel) return;

    let startX = 0;
    let isDragging = false;

    carousel.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX;
      isDragging = true;
    }, { passive: true });

    carousel.addEventListener('touchend', (e) => {
      if (!isDragging) return;
      const endX = e.changedTouches[0].clientX;
      const diff = startX - endX;

      if (Math.abs(diff) > 50) {
        if (diff > 0) {
          this.carouselNext();
        } else {
          this.carouselPrev();
        }
      }
      isDragging = false;
    }, { passive: true });
  }

  carouselPrev() {
    const track = document.getElementById('rm-modal-carousel-track');
    if (!track) return;

    const cardWidth = 110 + 12; // card width + gap
    this.carouselPosition = Math.min(0, this.carouselPosition + cardWidth * 2);
    track.style.transform = `translateX(${this.carouselPosition}px)`;
  }

  carouselNext() {
    const track = document.getElementById('rm-modal-carousel-track');
    const carousel = document.getElementById('rm-modal-carousel');
    if (!track || !carousel) return;

    const cardWidth = 110 + 12; // card width + gap
    const maxScroll = -(track.scrollWidth - carousel.clientWidth);
    this.carouselPosition = Math.max(maxScroll, this.carouselPosition - cardWidth * 2);
    track.style.transform = `translateX(${this.carouselPosition}px)`;
  }

  setQuantity(q) {
    this.quantity = Math.max(1, parseInt(q, 10) || 1);
    const el = document.getElementById('rm-modal-qty');
    if (el) el.textContent = this.quantity;
    this.updateTotal();
  }

  open(productData) {
    this.selectedProduct = productData;
    this.basePrice = parseInt(productData.price) || 0;
    this.quantity = 1;
    const qtyEl = document.getElementById('rm-modal-qty');
    if (qtyEl) qtyEl.textContent = '1';
    this.carouselPosition = 0;

    // Update modal content
    const imgEl = document.getElementById('rm-modal-image');
    const titleEl = document.getElementById('rm-modal-title');
    const descEl = document.getElementById('rm-modal-desc');
    const priceEl = document.getElementById('rm-modal-price');

    if (imgEl) {
      let imgSrc = productData.image || '';
      if (imgSrc && imgSrc.startsWith('//')) {
        imgSrc = 'https:' + imgSrc;
      }
      imgEl.src = imgSrc;
    }
    if (titleEl) titleEl.textContent = productData.title || '';
    if (descEl) descEl.textContent = productData.description || '';
    if (priceEl) priceEl.textContent = productData.priceFormatted || '';

    // Reset checkboxes and note
    this.modal.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = false);
    const noteEl = document.getElementById('rm-modal-note');
    if (noteEl) noteEl.value = '';

    // Reset carousel position
    const track = document.getElementById('rm-modal-carousel-track');
    if (track) track.style.transform = 'translateX(0)';

    // Update total
    if (this.isMenuPage) {
      this.updateTotal();
    }

    // Show modal
    this.modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  close() {
    this.modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';

    // Hide success/loading states
    document.getElementById('rm-modal-loading').style.display = 'none';
    document.getElementById('rm-modal-success').style.display = 'none';
    this.modal.querySelector('.rm-modal__content').style.display = '';
  }

  updateTotal() {
    let addons = 0;
    this.modal.querySelectorAll('input[type="checkbox"]:checked').forEach(input => {
      addons += parseInt(input.dataset.price) || 0;
    });

    // Quantity multiplies the base item; add-ons are added once per order.
    const total = (this.basePrice * this.quantity) + addons;

    const totalEl = document.getElementById('rm-modal-total');
    if (totalEl) {
      totalEl.textContent = this.formatMoney(total);
    }
  }

  async addToCart() {
    const loadingEl = document.getElementById('rm-modal-loading');
    const successEl = document.getElementById('rm-modal-success');
    const contentEl = this.modal.querySelector('.rm-modal__content');

    // Show loading
    contentEl.style.display = 'none';
    loadingEl.style.display = 'flex';

    // Collect items to add
    const items = [];

    // Main product
    const note = document.getElementById('rm-modal-note')?.value || '';
    items.push({
      id: this.selectedProduct.variantId,
      quantity: this.quantity,
      properties: note ? { 'Бележка': note } : {}
    });

    // Add selected addons
    this.modal.querySelectorAll('input[type="checkbox"]:checked').forEach(input => {
      items.push({
        id: parseInt(input.value),
        quantity: 1
      });
    });

    // Collect the cart sections so the drawer + bubble refresh after adding.
    const sectionIds = [];
    document.querySelectorAll('cart-items-component').forEach((c) => {
      if (c.dataset.sectionId && !sectionIds.includes(c.dataset.sectionId)) {
        sectionIds.push(c.dataset.sectionId);
      }
    });

    try {
      // One atomic add for all items (main + addons)
      const res = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/javascript' },
        body: JSON.stringify({
          items,
          sections: sectionIds.join(','),
          sections_url: window.location.pathname
        })
      });

      if (!res.ok) {
        let message = 'Грешка при добавяне.';
        try { const err = await res.json(); if (err.description) message = err.description; } catch (e) {}
        throw new Error(message);
      }

      const data = await res.json();

      // Pull the fresh cart so the bubble count + drawer reflect reality
      let cart = null;
      try { cart = await (await fetch('/cart.js')).json(); } catch (e) {}

      // Notify the theme: refreshes cart bubble (cart-icon) and morphs the
      // drawer contents (cart-items-component reads detail.data.sections).
      document.dispatchEvent(new CustomEvent('cart:update', {
        bubbles: true,
        detail: {
          resource: cart,
          sourceId: 'restaurant-modal',
          data: {
            source: 'product-form-component',
            itemCount: cart ? cart.item_count : items.length,
            sections: data.sections
          }
        }
      }));

      // Show success briefly, then close and open the drawer
      loadingEl.style.display = 'none';
      successEl.style.display = 'flex';

      setTimeout(() => {
        this.close();
        const drawer = document.querySelector('cart-drawer-component');
        if (drawer && typeof drawer.open === 'function') drawer.open();
      }, 900);

    } catch (error) {
      console.error('Error adding to cart:', error);
      loadingEl.style.display = 'none';
      contentEl.style.display = '';
      alert(error.message || 'Грешка при добавяне. Моля, опитайте отново.');
    }
  }
}

// Initialize
document.addEventListener('DOMContentLoaded', () => {
  window.restaurantModal = new RestaurantProductModal();
});
</script>

<style>
/* ===== Product modal — bottom sheet (mobile) / two-column (desktop) ===== */
.rm-modal {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: flex-end;          /* mobile: sheet docks to bottom */
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}

.rm-modal[aria-hidden="false"] {
  opacity: 1;
  visibility: visible;
}

.rm-modal__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.72);
  backdrop-filter: blur(3px);
}

/* Mobile: bottom sheet */
.rm-modal__container {
  position: relative;
  width: 100%;
  max-height: 94svh;
  background: var(--restaurant-dark-card, #1A1A1A);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  border-radius: 26px 26px 0 0;
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-bottom: none;
  transform: translateY(100%);
  transition: transform 0.42s cubic-bezier(0.22, 1, 0.36, 1);
  box-shadow: 0 -20px 60px -20px rgba(0, 0, 0, 0.7);
}

.rm-modal[aria-hidden="false"] .rm-modal__container {
  transform: translateY(0);
}

/* Desktop: centered two-column card */
@media screen and (min-width: 768px) {
  .rm-modal {
    align-items: center;
    padding: 2rem;
  }
  .rm-modal__container {
    max-width: 920px;
    width: 100%;
    max-height: 88vh;
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    transform: translateY(24px) scale(0.98);
    box-shadow: 0 40px 80px -30px rgba(0, 0, 0, 0.8);
  }
  .rm-modal[aria-hidden="false"] .rm-modal__container {
    transform: translateY(0) scale(1);
  }
}

/* Close */
.rm-modal__close {
  position: absolute;
  top: 0.85rem;
  right: 0.85rem;
  z-index: 10;
  background: rgba(13, 13, 13, 0.55);
  backdrop-filter: blur(6px);
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 50%;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  cursor: pointer;
  transition: background 0.2s ease, transform 0.3s ease;
}

.rm-modal__close:hover {
  background: var(--restaurant-accent, #F98760);
  transform: rotate(90deg);
}

/* Content layout */
.rm-modal__content {
  display: flex;
  flex-direction: column;        /* mobile: media over panel */
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

@media screen and (min-width: 768px) {
  .rm-modal__content {
    flex-direction: row;          /* desktop: media | panel */
    height: 88vh;
    max-height: 88vh;
  }
}

/* Media side */
.rm-modal__media {
  position: relative;
  width: 100%;
  flex-shrink: 0;
  aspect-ratio: 5 / 4;
  overflow: hidden;
  background: #0D0D0D;
}

@media screen and (min-width: 768px) {
  .rm-modal__media {
    width: 48%;
    aspect-ratio: auto;
    height: 100%;
  }
}

.rm-modal__media-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Mobile drag handle */
.rm-modal__handle {
  position: absolute;
  top: 0.6rem;
  left: 50%;
  transform: translateX(-50%);
  width: 44px;
  height: 4px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.55);
  z-index: 3;
}
@media screen and (min-width: 768px) { .rm-modal__handle { display: none; } }

/* ◇ brand tag on the image */
.rm-modal__media-tag {
  position: absolute;
  bottom: 0.85rem;
  left: 0.85rem;
  z-index: 2;
  display: inline-flex;
  align-items: center;
  gap: 0.45em;
  padding: 0.35rem 0.8rem;
  background: rgba(13, 13, 13, 0.6);
  backdrop-filter: blur(6px);
  border: 1px solid rgba(249, 135, 96, 0.4);
  border-radius: 999px;
  font-family: var(--font-body--family);
  font-size: 0.6rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: #fff;
}
.rm-modal__media-diamond { color: var(--restaurant-accent, #F98760); font-size: 0.85em; }

/* Order panel */
.rm-modal__panel {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-height: 0;
  background: var(--restaurant-dark-card, #1A1A1A);
}

.rm-modal__panel-scroll {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  padding: 1.25rem 1.25rem 0.5rem;
  -webkit-overflow-scrolling: touch;
}

@media screen and (min-width: 768px) {
  .rm-modal__panel-scroll { padding: 2.25rem 2rem 0.75rem; }
}

/* Head: title + price */
.rm-modal__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1rem;
}

.rm-modal__product-title {
  font-family: var(--font-heading--family);
  font-weight: var(--font-heading--weight);
  font-size: clamp(1.35rem, 4.5vw, 1.85rem);
  line-height: 1.12;
  color: #fff;
  margin: 0;
}

.rm-modal__price {
  font-family: var(--font-heading--family);
  font-weight: var(--font-heading--weight);
  font-size: clamp(1.2rem, 4vw, 1.6rem);
  color: var(--restaurant-accent, #F98760);
  white-space: nowrap;
  flex-shrink: 0;
