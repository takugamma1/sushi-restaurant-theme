{%- doc -%}
  Restaurant product modal component - Single page design.
  - Home page: Preview only with "See full menu" button
  - Menu page: Full ordering with add-ons carousel and note

  @param {object} addons_collection - Collection for add-ons products
  @param {string} addons_title - Title for the add-ons section
  @param {string} menu_page_url - URL for the full menu page
{%- enddoc -%}

{%- liquid
  assign is_menu_page = false
  if template.suffix == 'menu' or request.path contains '/pages/menu'
    assign is_menu_page = true
  endif

  assign menu_page_url = menu_page_url | default: '/pages/menu'
  assign addons_title = addons_title | default: 'Добави към поръчката'
-%}

<div class="rm-modal" id="rm-product-modal" aria-hidden="true">
  <div class="rm-modal__backdrop" data-close-modal></div>
  <div class="rm-modal__container">
    <button class="rm-modal__close" type="button" data-close-modal aria-label="Close">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    {%- comment -%} Modal content wrapper {%- endcomment -%}
    <div class="rm-modal__content">
      {%- comment -%} Big product image {%- endcomment -%}
      <div class="rm-modal__hero-image">
        <img src="" alt="" id="rm-modal-image">
      </div>

      {%- comment -%} Product info {%- endcomment -%}
      <div class="rm-modal__product-info">
        <h3 class="rm-modal__product-title" id="rm-modal-title"></h3>
        <p class="rm-modal__product-desc" id="rm-modal-desc"></p>
        <div class="rm-modal__product-price" id="rm-modal-price"></div>
      </div>

      {%- if is_menu_page -%}
        {%- comment -%} Add-ons section with carousel {%- endcomment -%}
        {%- if addons_collection != blank and addons_collection.products.size > 0 -%}
          <div class="rm-modal__addons-section">
            <h4 class="rm-modal__addons-title">{{ addons_title }} <span class="rm-modal__optional">(по желание)</span></h4>

            <div class="rm-modal__carousel-wrapper">
              <button type="button" class="rm-modal__carousel-btn rm-modal__carousel-btn--prev" data-carousel-prev aria-label="Previous">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="15 18 9 12 15 6"></polyline>
                </svg>
              </button>

              <div class="rm-modal__carousel" id="rm-modal-carousel">
                <div class="rm-modal__carousel-track" id="rm-modal-carousel-track">
                  {%- for product in addons_collection.products limit: 20 -%}
                    <label class="rm-modal__addon-card">
                      <input
                        type="checkbox"
                        name="addon[]"
                        value="{{ product.selected_or_first_available_variant.id }}"
                        data-price="{{ product.price }}"
                        data-title="{{ product.title | escape }}"
                      >
                      <span class="rm-modal__addon-card-inner">
                        <span class="rm-modal__addon-image">
                          {%- if product.featured_image != blank -%}
                            <img
                              src="{{ product.featured_image | image_url: width: 300, height: 300, crop: 'center' }}"
                              alt="{{ product.featured_image.alt | escape }}"
                              loading="lazy"
                            >
                          {%- else -%}
                            <span class="rm-modal__addon-placeholder"></span>
                          {%- endif -%}
                        </span>
                        <span class="rm-modal__addon-details">
                          <span class="rm-modal__addon-name">{{ product.title }}</span>
                          <span class="rm-modal__addon-price">+{{ product.price | money }}</span>
                        </span>
                        <span class="rm-modal__addon-check">
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                            <polyline points="20 6 9 17 4 12"></polyline>
                          </svg>
                        </span>
                      </span>
                    </label>
                  {%- endfor -%}
                </div>
              </div>

              <button type="button" class="rm-modal__carousel-btn rm-modal__carousel-btn--next" data-carousel-next aria-label="Next">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
              </button>
            </div>
          </div>
        {%- endif -%}

        {%- comment -%} Order note {%- endcomment -%}
        <div class="rm-modal__note-section">
          <h4 class="rm-modal__note-label">Бележка към поръчката <span class="rm-modal__optional">(по желание)</span></h4>
          <textarea
            class="rm-modal__note"
            id="rm-modal-note"
            placeholder="Напр: Без лук, допълнително сусам, алергии..."
            rows="2"
          ></textarea>
        </div>

        {%- comment -%} Footer with total and add button {%- endcomment -%}
        <div class="rm-modal__footer">
          <div class="rm-modal__total">
            <span class="rm-modal__total-label">Общо:</span>
            <span class="rm-modal__total-price" id="rm-modal-total">0.00 лв.</span>
          </div>
          <button type="button" class="rm-modal__btn rm-modal__btn--add" data-add-to-cart>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="9" cy="21" r="1"></circle>
              <circle cx="20" cy="21" r="1"></circle>
              <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
            </svg>
            Добави в кошницата
          </button>
        </div>

      {%- else -%}
        {%- comment -%} Home page: Preview only {%- endcomment -%}
        <div class="rm-modal__preview-footer">
          <a href="{{ menu_page_url }}" class="rm-modal__btn rm-modal__btn--full">
            Виж пълното меню
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </a>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Loading state {%- endcomment -%}
    <div class="rm-modal__loading" id="rm-modal-loading" style="display: none;">
      <div class="rm-modal__spinner"></div>
      <span>Добавяне...</span>
    </div>

    {%- comment -%} Success state {%- endcomment -%}
    <div class="rm-modal__success" id="rm-modal-success" style="display: none;">
      <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
        <polyline points="22 4 12 14.01 9 11.01"></polyline>
      </svg>
      <span>Добавено в кошницата!</span>
    </div>
  </div>
</div>

<script>
class RestaurantProductModal {
  constructor() {
    this.modal = document.getElementById('rm-product-modal');
    if (!this.modal) return;

    this.isMenuPage = {{ is_menu_page | json }};
    this.selectedProduct = null;
    this.basePrice = 0;
    this.carouselPosition = 0;

    this.bindEvents();
  }

  bindEvents() {
    // Close modal
    this.modal.querySelectorAll('[data-close-modal]').forEach(btn => {
      btn.addEventListener('click', () => this.close());
    });

    // Close on escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && this.modal.getAttribute('aria-hidden') === 'false') {
        this.close();
      }
    });

    if (this.isMenuPage) {
      // Add to cart
      const addBtn = this.modal.querySelector('[data-add-to-cart]');
      if (addBtn) addBtn.addEventListener('click', () => this.addToCart());

      // Update total on addon change
      this.modal.querySelectorAll('input[type="checkbox"]').forEach(input => {
        input.addEventListener('change', () => this.updateTotal());
      });

      // Carousel navigation
      const prevBtn = this.modal.querySelector('[data-carousel-prev]');
      const nextBtn = this.modal.querySelector('[data-carousel-next]');
      if (prevBtn) prevBtn.addEventListener('click', () => this.carouselPrev());
      if (nextBtn) nextBtn.addEventListener('click', () => this.carouselNext());

      // Touch swipe for carousel
      this.initCarouselTouch();
    }
  }

  initCarouselTouch() {
    const carousel = document.getElementById('rm-modal-carousel');
    if (!carousel) return;

    let startX = 0;
    let isDragging = false;

    carousel.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX;
      isDragging = true;
    }, { passive: true });

    carousel.addEventListener('touchend', (e) => {
      if (!isDragging) return;
      const endX = e.changedTouches[0].clientX;
      const diff = startX - endX;

      if (Math.abs(diff) > 50) {
        if (diff > 0) {
          this.carouselNext();
        } else {
          this.carouselPrev();
        }
      }
      isDragging = false;
    }, { passive: true });
  }

  carouselPrev() {
    const track = document.getElementById('rm-modal-carousel-track');
    if (!track) return;

    const cardWidth = 140 + 12; // card width + gap
    this.carouselPosition = Math.min(0, this.carouselPosition + cardWidth * 2);
    track.style.transform = `translateX(${this.carouselPosition}px)`;
  }

  carouselNext() {
    const track = document.getElementById('rm-modal-carousel-track');
    const carousel = document.getElementById('rm-modal-carousel');
    if (!track || !carousel) return;

    const cardWidth = 140 + 12; // card width + gap
    const maxScroll = -(track.scrollWidth - carousel.clientWidth);
    this.carouselPosition = Math.max(maxScroll, this.carouselPosition - cardWidth * 2);
    track.style.transform = `translateX(${this.carouselPosition}px)`;
  }

  open(productData) {
    this.selectedProduct = productData;
    this.basePrice = parseInt(productData.price) || 0;
    this.carouselPosition = 0;

    // Update modal content
    const imgEl = document.getElementById('rm-modal-image');
    const titleEl = document.getElementById('rm-modal-title');
    const descEl = document.getElementById('rm-modal-desc');
    const priceEl = document.getElementById('rm-modal-price');

    if (imgEl) {
      let imgSrc = productData.image || '';
      if (imgSrc && imgSrc.startsWith('//')) {
        imgSrc = 'https:' + imgSrc;
      }
      imgEl.src = imgSrc;
    }
    if (titleEl) titleEl.textContent = productData.title || '';
    if (descEl) descEl.textContent = productData.description || '';
    if (priceEl) priceEl.textContent = productData.priceFormatted || '';

    // Reset checkboxes and note
    this.modal.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = false);
    const noteEl = document.getElementById('rm-modal-note');
    if (noteEl) noteEl.value = '';

    // Reset carousel position
    const track = document.getElementById('rm-modal-carousel-track');
    if (track) track.style.transform = 'translateX(0)';

    // Update total
    if (this.isMenuPage) {
      this.updateTotal();
    }

    // Show modal
    this.modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  close() {
    this.modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';

    // Hide success/loading states
    document.getElementById('rm-modal-loading').style.display = 'none';
    document.getElementById('rm-modal-success').style.display = 'none';
    this.modal.querySelector('.rm-modal__content').style.display = '';
  }

  updateTotal() {
    let total = this.basePrice;

    this.modal.querySelectorAll('input[type="checkbox"]:checked').forEach(input => {
      total += parseInt(input.dataset.price) || 0;
    });

    const totalEl = document.getElementById('rm-modal-total');
    if (totalEl) {
      totalEl.textContent = (total / 100).toFixed(2) + ' лв.';
    }
  }

  async addToCart() {
    const loadingEl = document.getElementById('rm-modal-loading');
    const successEl = document.getElementById('rm-modal-success');
    const contentEl = this.modal.querySelector('.rm-modal__content');

    // Show loading
    contentEl.style.display = 'none';
    loadingEl.style.display = 'flex';

    // Collect items to add
    const items = [];

    // Main product
    const note = document.getElementById('rm-modal-note')?.value || '';
    items.push({
      id: this.selectedProduct.variantId,
      quantity: 1,
      properties: note ? { 'Бележка': note } : {}
    });

    // Add selected addons
    this.modal.querySelectorAll('input[type="checkbox"]:checked').forEach(input => {
      items.push({
        id: parseInt(input.value),
        quantity: 1
      });
    });

    try {
      // Add items to cart
      for (const item of items) {
        await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(item)
        });
      }

      // Show success
      loadingEl.style.display = 'none';
      successEl.style.display = 'flex';

      // Close after delay
      setTimeout(() => {
        this.close();
        // Refresh cart count if available
        if (window.refreshCartCount) window.refreshCartCount();
      }, 1500);

    } catch (error) {
      console.error('Error adding to cart:', error);
      loadingEl.style.display = 'none';
      contentEl.style.display = '';
      alert('Грешка при добавяне. Моля, опитайте отново.');
    }
  }
}

// Initialize
document.addEventListener('DOMContentLoaded', () => {
  window.restaurantModal = new RestaurantProductModal();
});
</script>

<style>
/* Modal Base */
.rm-modal {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1rem;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}

.rm-modal[aria-hidden="false"] {
  opacity: 1;
  visibility: visible;
}

.rm-modal__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.9);
  backdrop-filter: blur(8px);
}

.rm-modal__container {
  position: relative;
  width: 100%;
  max-width: 500px;
  max-height: 90vh;
  background: var(--restaurant-dark-card, #1A1A1A);
  border-radius: 24px;
  border: 1px solid var(--restaurant-border, #2A2A2A);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transform: translateY(20px) scale(0.95);
  transition: transform 0.3s ease;
}

.rm-modal[aria-hidden="false"] .rm-modal__container {
  transform: translateY(0) scale(1);
}

/* Close button */
.rm-modal__close {
  position: absolute;
  top: 0.75rem;
  right: 0.75rem;
  z-index: 10;
  background: rgba(0, 0, 0, 0.6);
  border: 1px solid rgba(255, 255, 255, 0.15);
  border-radius: 50%;
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  cursor: pointer;
  transition: background 0.2s ease, transform 0.2s ease;
}

.rm-modal__close:hover {
  background: rgba(0, 0, 0, 0.8);
  transform: scale(1.1);
}

/* Content */
.rm-modal__content {
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* Hero image - mobile first approach */
.rm-modal__hero-image {
  position: relative;
  width: 100%;
  min-height: 200px;
  max-height: 280px;
  overflow: hidden;
  background: radial-gradient(ellipse at center, #1a1a1a 0%, #0D0D0D 70%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 3.5rem 1.5rem 1.5rem;
}

.rm-modal__hero-image::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 50% 50%, rgba(249, 135, 96, 0.06) 0%, transparent 60%);
  pointer-events: none;
}

.rm-modal__hero-image img {
  max-width: 100%;
  max-height: 100%;
  width: auto;
  height: auto;
  object-fit: contain;
  position: relative;
  z-index: 1;
  filter: drop-shadow(0 6px 20px rgba(0, 0, 0, 0.4));
}

/* Desktop - larger hero image */
@media screen and (min-width: 541px) {
  .rm-modal__hero-image {
    min-height: 280px;
    max-height: 340px;
    padding: 3rem 2rem 1.5rem;
  }

  .rm-modal__hero-image img {
    filter: drop-shadow(0 8px 24px rgba(0, 0, 0, 0.4));
    transition: transform 0.4s ease;
  }

  .rm-modal__hero-image img:hover {
    transform: scale(1.03);
  }
}

/* Product info */
.rm-modal__product-info {
  padding: 1.25rem 1.5rem;
  border-bottom: 1px solid var(--restaurant-border, #2A2A2A);
}

.rm-modal__product-title {
  font-family: var(--font-heading--family);
  font-size: 1.5rem;
  font-weight: 600;
  color: #fff;
  margin: 0 0 0.5rem;
  line-height: 1.2;
}

.rm-modal__product-desc {
  font-size: 0.9rem;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.5;
  margin: 0 0 0.75rem;
}

.rm-modal__product-price {
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--restaurant-accent, #F98760);
}

/* Add-ons section */
.rm-modal__addons-section {
  padding: 1.25rem 0;
  border-bottom: 1px solid var(--restaurant-border, #2A2A2A);
}

.rm-modal__addons-title {
  font-size: 0.95rem;
  font-weight: 600;
  color: #fff;
  margin: 0 0 1rem;
  padding: 0 1.5rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.rm-modal__optional {
  font-weight: 400;
  font-size: 0.8rem;
  color: rgba(255, 255, 255, 0.4);
}

/* Carousel wrapper */
.rm-modal__carousel-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0 0.5rem;
}

.rm-modal__carousel {
  flex: 1;
  overflow: hidden;
  padding: 0.25rem 0;
}

.rm-modal__carousel-track {
  display: flex;
  gap: 12px;
  transition: transform 0.3s ease;
  padding: 0 0.5rem;
}

/* Carousel navigation buttons */
.rm-modal__carousel-btn {
  flex-shrink: 0;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid var(--restaurant-border, #2A2A2A);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s ease;
}

.rm-modal__carousel-btn:hover {
  background: var(--restaurant-accent, #F98760);
  border-color: var(--restaurant-accent, #F98760);
}

/* Add-on card */
.rm-modal__addon-card {
  flex-shrink: 0;
  width: 140px;
  cursor: pointer;
}

.rm-modal__addon-card input {
  display: none;
}

.rm-modal__addon-card-inner {
  display: flex;
  flex-direction: column;
  background: rgba(255, 255, 255, 0.03);
  border: 2px solid var(--restaurant-border, #2A2A2A);
  border-radius: 16px;
  overflow: hidden;
  transition: all 0.25s ease;
  position: relative;
}

.rm-modal__addon-card:hover .rm-modal__addon-card-inner {
  border-color: rgba(255, 255, 255, 0.2);
  background: rgba(255, 255, 255, 0.05);
}

.rm-modal__addon-card input:checked + .rm-modal__addon-card-inner {
  border-color: var(--restaurant-accent, #F98760);
  background: rgba(249, 135, 96, 0.1);
}

/* Add-on image */
.rm-modal__addon-image {
  width: 100%;
  aspect-ratio: 1;
  overflow: hidden;
  background: #0D0D0D;
}

.rm-modal__addon-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.rm-modal__addon-card:hover .rm-modal__addon-image img {
  transform: scale(1.05);
}

.rm-modal__addon-placeholder {
  display: block;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #2A2A2A 0%, #1A1A1A 100%);
}

/* Add-on details */
.rm-modal__addon-details {
  padding: 0.75rem;
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.rm-modal__addon-name {
  font-size: 0.8rem;
  font-weight: 500;
  color: #fff;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.rm-modal__addon-price {
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--restaurant-accent, #F98760);
}

/* Checkmark */
.rm-modal__addon-check {
  position: absolute;
  top: 8px;
  right: 8px;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: var(--restaurant-accent, #F98760);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  opacity: 0;
  transform: scale(0.5);
  transition: all 0.25s ease;
}

.rm-modal__addon-card input:checked + .rm-modal__addon-card-inner .rm-modal__addon-check {
  opacity: 1;
  transform: scale(1);
}

/* Note section */
.rm-modal__note-section {
  padding: 1.25rem 1.5rem;
}

.rm-modal__note-label {
  font-size: 0.95rem;
  font-weight: 600;
  color: #fff;
  margin: 0 0 0.75rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.rm-modal__note {
  width: 100%;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid var(--restaurant-border, #2A2A2A);
  border-radius: 12px;
  padding: 0.875rem 1rem;
  color: #fff;
  font-size: 0.9rem;
  resize: none;
  font-family: inherit;
  transition: border-color 0.2s ease;
}

.rm-modal__note::placeholder {
  color: rgba(255, 255, 255, 0.3);
}

.rm-modal__note:focus {
  outline: none;
  border-color: var(--restaurant-accent, #F98760);
}

/* Footer */
.rm-modal__footer {
  padding: 1.25rem 1.5rem;
  background: rgba(0, 0, 0, 0.4);
  border-top: 1px solid var(--restaurant-border, #2A2A2A);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}

.rm-modal__total {
  display: flex;
  flex-direction: column;
  gap: 0.125rem;
}

.rm-modal__total-label {
  font-size: 0.8rem;
  color: rgba(255, 255, 255, 0.5);
}

.rm-modal__total-price {
  font-size: 1.5rem;
  font-weight: 700;
  color: #fff;
}

/* Buttons */
.rm-modal__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 1rem 1.75rem;
  border: none;
  border-radius: 12px;
