{%- doc -%}
  Restaurant mobile drawer menu with custom navigation links.
  Rendered in restaurant mode to replace default drawer menu.
  Links are configurable via section settings.
{%- enddoc -%}

{%- liquid
  assign nav_1_label = section.settings.nav_1_label | default: 'Начало'
  assign nav_1_url = section.settings.nav_1_url | default: '/'
  assign nav_2_label = section.settings.nav_2_label | default: 'Меню'
  assign nav_2_url = section.settings.nav_2_url | default: '/pages/menu'
  assign nav_3_label = section.settings.nav_3_label | default: 'Комбота'
  assign nav_3_url = section.settings.nav_3_url | default: '/pages/combos'
  assign nav_4_label = section.settings.nav_4_label | default: 'Ревюта'
  assign nav_4_url = section.settings.nav_4_url | default: '/pages/reviews'
  assign nav_5_label = section.settings.nav_5_label | default: 'За нас'
  assign nav_5_url = section.settings.nav_5_url | default: '/pages/about'
  assign nav_6_label = section.settings.nav_6_label | default: 'Контакти'
  assign nav_6_url = section.settings.nav_6_url | default: '/pages/contact'
  assign cta_label = section.settings.drawer_cta_label | default: 'Поръчай сега'
  assign cta_url = section.settings.drawer_cta_url | default: '/pages/menu'
-%}

<script
  src="{{ 'header-drawer.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<header-drawer class="header-drawer restaurant-drawer">
  <details
    id="Details-restaurant-drawer"
    data-skip-node-update="true"
    class="menu-drawer-container"
    ref="details"
    scroll-lock
  >
    <summary
      class="header__icon header__icon--menu header__icon--summary"
      aria-label="{{ 'accessibility.menu' | t }}"
      on:click="/toggle"
    >
      <span class="svg-wrapper header-drawer-icon header-drawer-icon--open">
        {{- 'icon-menu.svg' | inline_asset_content -}}
      </span>
      <span class="svg-wrapper header-drawer-icon header-drawer-icon--close">
        {{- 'icon-close.svg' | inline_asset_content -}}
      </span>
    </summary>

    <div ref="menuDrawer" class="menu-drawer restaurant-drawer__panel">
      <button
        class="button close-button menu-drawer__close-button"
        type="button"
        aria-label="{{ 'actions.close' | t }}"
        on:click="/close"
      >
        <span class="svg-wrapper header-drawer-icon header-drawer-icon--close">
          {{- 'icon-close.svg' | inline_asset_content -}}
        </span>
      </button>

      <nav class="restaurant-drawer__nav" aria-label="Mobile restaurant navigation">
        <ul class="restaurant-drawer__menu" role="list">
          {%- if nav_1_label != blank -%}
            <li class="restaurant-drawer__item" style="--animation-index: 1;">
              <a href="{{ nav_1_url }}" class="restaurant-drawer__link" on:click="/close">
                <span class="restaurant-drawer__link-text">{{ nav_1_label }}</span>
              </a>
            </li>
          {%- endif -%}
          {%- if nav_2_label != blank -%}
            <li class="restaurant-drawer__item" style="--animation-index: 2;">
              <a href="{{ nav_2_url }}" class="restaurant-drawer__link" on:click="/close">
                <span class="restaurant-drawer__link-text">{{ nav_2_label }}</span>
              </a>
            </li>
          {%- endif -%}
          {%- if nav_3_label != blank -%}
            <li class="restaurant-drawer__item" style="--animation-index: 3;">
              <a href="{{ nav_3_url }}" class="restaurant-drawer__link" on:click="/close">
                <span class="restaurant-drawer__link-text">{{ nav_3_label }}</span>
              </a>
            </li>
          {%- endif -%}
          {%- if nav_4_label != blank -%}
            <li class="restaurant-drawer__item" style="--animation-index: 4;">
              <a href="{{ nav_4_url }}" class="restaurant-drawer__link" on:click="/close">
                <span class="restaurant-drawer__link-text">{{ nav_4_label }}</span>
              </a>
            </li>
          {%- endif -%}
          {%- if nav_5_label != blank -%}
            <li class="restaurant-drawer__item" style="--animation-index: 5;">
              <a href="{{ nav_5_url }}" class="restaurant-drawer__link" on:click="/close">
                <span class="restaurant-drawer__link-text">{{ nav_5_label }}</span>
              </a>
            </li>
          {%- endif -%}
          {%- if nav_6_label != blank -%}
            <li class="restaurant-drawer__item" style="--animation-index: 6;">
              <a href="{{ nav_6_url }}" class="restaurant-drawer__link" on:click="/close">
                <span class="restaurant-drawer__link-text">{{ nav_6_label }}</span>
              </a>
            </li>
          {%- endif -%}
        </ul>
      </nav>

      {%- if cta_label != blank -%}
        <div class="restaurant-drawer-cta">
          <a href="{{ cta_url }}" class="restaurant-drawer-cta__button" on:click="/close">
            {{ cta_label }}
          </a>
        </div>
      {%- endif -%}
    </div>

    <div class="menu-drawer__backdrop" on:click="/close"></div>
  </details>
</header-drawer>

{% stylesheet %}
  /* Restaurant Drawer Panel */
  .restaurant-drawer__panel {
    position: fixed;
    transform: translateX(-100%);
    visibility: hidden;
    height: 100dvh;
    width: 100%;
    max-width: 320px;
    z-index: var(--layer-menu-drawer, 100);
    left: 0;
    top: 0;
    padding: 0;
    background: var(--restaurant-dark, #0D0D0D);
    overflow: auto;
    display: flex;
    flex-direction: column;
    border-right: 1px solid var(--restaurant-border, #2A2A2A);
    transition: transform 0.35s ease, visibility 0.35s ease;
  }

  .menu-open > .restaurant-drawer__panel {
    transform: translateX(0);
    visibility: visible;
  }

  /* Navigation */
  .restaurant-drawer__nav {
    flex: 1;
    padding: 5rem 1.5rem 2rem;
  }

  .restaurant-drawer__menu {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .restaurant-drawer__item {
    opacity: 0;
    transform: translateX(-1rem);
  }

  .menu-open .restaurant-drawer__item {
    animation: restaurantDrawerItemIn 0.4s ease forwards;
    animation-delay: calc(0.1s + var(--animation-index) * 0.05s);
  }

  @keyframes restaurantDrawerItemIn {
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .restaurant-drawer__link {
    display: block;
    padding: 1rem 0;
    color: #fff;
    text-decoration: none;
    font-family: var(--font-heading--family);
    font-size: 1.25rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--restaurant-border, #2A2A2A);
    transition: color 0.3s ease, padding-left 0.3s ease;
  }

  .restaurant-drawer__link:hover {
    color: var(--restaurant-accent, #F98760);
    padding-left: 0.5rem;
  }

  .restaurant-drawer__link-text {
    display: block;
  }

  /* Close button */
  .restaurant-drawer__panel .menu-drawer__close-button {
    position: absolute;
    top: 1rem;
    right: 1rem;
    color: #fff;
    padding: 0.75rem;
    z-index: 10;
  }

  .restaurant-drawer__panel .menu-drawer__close-button:hover {
    color: var(--restaurant-accent, #F98760);
  }

  /* CTA in drawer */
  .restaurant-drawer .restaurant-drawer-cta {
    padding: 1.5rem;
    margin-top: auto;
    border-top: 1px solid var(--restaurant-border, #2A2A2A);
  }
{% endstylesheet %}
