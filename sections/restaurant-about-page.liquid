{%- liquid
  assign menu_url = section.settings.menu_url | default: '/pages/menu'
  assign contact_url = section.settings.contact_url | default: '/pages/contact'
  assign marquee_word = section.settings.marquee_word | default: 'MANGO'
-%}

<div class="rab">

  {%- comment -%} ============ Hero (bento) ============ {%- endcomment -%}
  {%- liquid
    assign side1_link = section.settings.side1_link | default: menu_url
    assign side2_link = section.settings.side2_link | default: contact_url
    assign side3_link = section.settings.side3_link | default: '/pages/gallery'
  -%}
  <section class="rab__hero">
    <div class="rab__hero-grid">

      {%- comment -%} Main card (left) {%- endcomment -%}
      <div class="rab__hero-main">
        <div class="rab__hero-main-media">
          {%- if section.settings.hero_image != blank -%}
            {{ section.settings.hero_image
              | image_url: width: 2200
              | image_tag:
                class: 'rab__hero-image',
                sizes: '(min-width: 990px) 58vw, 100vw',
                widths: '700,1100,1500,1900,2200',
                loading: 'eager',
                fetchpriority: 'high'
            }}
          {%- else -%}
            <div class="rab__hero-image rab__hero-image--placeholder"></div>
          {%- endif -%}
          <div class="rab__hero-overlay"></div>
        </div>

        <div class="rab__hero-main-body">
          <h1 class="rab__hero-title">
            <em>{{ section.settings.hero_title | default: 'За нас' }}</em>
          </h1>
          {%- if section.settings.hero_subtitle != blank -%}
            <p class="rab__hero-subtitle">{{ section.settings.hero_subtitle }}</p>
          {%- else -%}
            <p class="rab__hero-subtitle">Добре дошли в Суши Бар Манго — място, където свежестта и вкусът се срещат.</p>
          {%- endif -%}
          <a href="{{ section.settings.hero_cta_link | default: menu_url }}" class="rab__hero-cta">
            <span>{{ section.settings.hero_cta_label | default: 'РАЗБЕРИ ПОВЕЧЕ' }}</span>
            <span class="rab__arrow-circle" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </a>
        </div>
      </div>

      {%- comment -%} Side cards (right) {%- endcomment -%}
      <div class="rab__hero-side">
        <a href="{{ side1_link }}" class="rab__hero-card">
          {%- if section.settings.side1_image != blank -%}
            {{ section.settings.side1_image
              | image_url: width: 1100
              | image_tag:
                class: 'rab__hero-card-image',
                sizes: '(min-width: 990px) 40vw, 100vw',
                widths: '400,700,1100',
                loading: 'lazy'
            }}
          {%- else -%}
            <div class="rab__hero-card-image rab__hero-card-image--placeholder"></div>
          {%- endif -%}
          <span class="rab__hero-card-cta">
            <span class="rab__hero-card-label">{{ section.settings.side1_label | default: 'ПОРЪЧАЙ' }}</span>
            <span class="rab__arrow-circle rab__arrow-circle--light" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </span>
        </a>

        <a href="{{ side2_link }}" class="rab__hero-card">
          {%- if section.settings.side2_image != blank -%}
            {{ section.settings.side2_image
              | image_url: width: 1100
              | image_tag:
                class: 'rab__hero-card-image',
                sizes: '(min-width: 990px) 40vw, 100vw',
                widths: '400,700,1100',
                loading: 'lazy'
            }}
          {%- else -%}
            <div class="rab__hero-card-image rab__hero-card-image--placeholder"></div>
          {%- endif -%}
          <span class="rab__hero-card-cta">
            <span class="rab__hero-card-label">{{ section.settings.side2_label | default: 'СВЪРЖИ СЕ С НАС' }}</span>
            <span class="rab__arrow-circle rab__arrow-circle--light" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </span>
        </a>

        <a href="{{ side3_link }}" class="rab__hero-card">
          {%- if section.settings.side3_image != blank -%}
            {{ section.settings.side3_image
              | image_url: width: 1100
              | image_tag:
                class: 'rab__hero-card-image',
                sizes: '(min-width: 990px) 40vw, 100vw',
                widths: '400,700,1100',
                loading: 'lazy'
            }}
          {%- else -%}
            <div class="rab__hero-card-image rab__hero-card-image--placeholder"></div>
          {%- endif -%}
          <span class="rab__hero-card-cta">
            <span class="rab__hero-card-label">{{ section.settings.side3_label | default: 'ГАЛЕРИЯ' }}</span>
            <span class="rab__arrow-circle rab__arrow-circle--light" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </span>
        </a>
      </div>
    </div>
  </section>

  {%- comment -%} ============ Marquee ============ {%- endcomment -%}
  <div class="rab__marquee" aria-hidden="true">
    <div class="rab__marquee-track">
      {%- for i in (1..2) -%}
        {%- for j in (1..6) -%}
          <span class="rab__marquee-word">{{ marquee_word }}</span>
          <span class="rab__marquee-dia">◇</span>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%} ============ Story ============ {%- endcomment -%}
  <section class="rab__story">
    <span class="rab__watermark" aria-hidden="true">{{ section.settings.year | default: '2012' }}</span>

    <div class="rab__story-inner">
      <div class="rab__story-text">
        <span class="rab__kicker">
          <span class="rab__kicker-num">№01</span>
          <span class="rab__kicker-line"></span>
          <span class="rab__kicker-text">{{ section.settings.story_kicker | default: 'НАШАТА ИСТОРИЯ' }}</span>
        </span>

        <h2 class="rab__story-heading">
          {{ section.settings.story_line_1 | default: 'Една кухня,' }}<br>
          {{ section.settings.story_line_2 | default: 'една' }}
          <em>{{ section.settings.story_line_2_em | default: 'страст.' }}</em>
        </h2>

        <p class="rab__story-lead">
          <span class="rab__dropcap">{{ section.settings.dropcap | default: 'М' }}</span>{{ section.settings.story_lead | default: 'анго е родено от любовта към японската традиция и желанието да донесем истинското суши в България. От една малка кухня преди повече от десет години — до място, в което се срещат майсторски нож, прясна риба и съвременна атмосфера.' }}
        </p>

        <p class="rab__story-body">{{ section.settings.story_body | default: 'Всяко рулце е приготвено ръчно — с уважение към продукта и с прецизност, която сме научили от истинските майстори на занаята.' }}</p>

        <div class="rab__story-stats">
          <div class="rab__stat">
            <span class="rab__stat-num">{{ section.settings.stat_1_num | default: '10+' }}</span>
            <span class="rab__stat-label">{{ section.settings.stat_1_label | default: 'години' }}</span>
          </div>
          <div class="rab__stat">
            <span class="rab__stat-num">{{ section.settings.stat_2_num | default: '120' }}</span>
            <span class="rab__stat-label">{{ section.settings.stat_2_label | default: 'ястия' }}</span>
          </div>
          <div class="rab__stat">
            <span class="rab__stat-num">{{ section.settings.stat_3_num | default: '50k+' }}</span>
            <span class="rab__stat-label">{{ section.settings.stat_3_label | default: 'клиенти' }}</span>
          </div>
        </div>
      </div>

      <figure class="rab__story-photo">
        {%- if section.settings.story_image != blank -%}
          {{ section.settings.story_image
            | image_url: width: 1200
            | image_tag:
              class: 'rab__story-image',
              sizes: '(min-width: 990px) 40vw, 80vw',
              widths: '500,800,1100,1400',
              loading: 'lazy'
          }}
        {%- else -%}
          <div class="rab__story-image rab__story-image--placeholder"></div>
        {%- endif -%}
        {%- if section.settings.story_caption != blank -%}
          <figcaption class="rab__photo-caption">— {{ section.settings.story_caption }}</figcaption>
        {%- endif -%}
      </figure>
    </div>
  </section>

  {%- comment -%} ============ Photo Collage ============ {%- endcomment -%}
  <section class="rab__collage">
    <div class="rab__collage-header">
      <span class="rab__kicker">
        <span class="rab__kicker-num">№02</span>
        <span class="rab__kicker-line"></span>
        <span class="rab__kicker-text">{{ section.settings.collage_kicker | default: 'МОМЕНТИ' }}</span>
      </span>
      <h2 class="rab__collage-heading">
        {{ section.settings.collage_line_1 | default: 'Прецизност' }} <em>—</em><br>
        {{ section.settings.collage_line_2 | default: 'хапка по хапка.' }}
      </h2>
    </div>

    <div class="rab__collage-grid">
      <figure class="rab__collage-item rab__collage-item--a">
        {%- if section.settings.collage_image_1 != blank -%}
          {{ section.settings.collage_image_1 | image_url: width: 1200 | image_tag: class: 'rab__collage-image', sizes: '50vw', widths: '500,800,1200', loading: 'lazy' }}
        {%- else -%}
          <div class="rab__collage-image rab__collage-image--placeholder"></div>
        {%- endif -%}
        <figcaption class="rab__photo-caption rab__photo-caption--top-left">— {{ section.settings.collage_caption_1 | default: 'ножът' }}</figcaption>
      </figure>

      <figure class="rab__collage-item rab__collage-item--b">
        {%- if section.settings.collage_image_2 != blank -%}
          {{ section.settings.collage_image_2 | image_url: width: 800 | image_tag: class: 'rab__collage-image', sizes: '25vw', widths: '300,500,800', loading: 'lazy' }}
        {%- else -%}
          <div class="rab__collage-image rab__collage-image--placeholder"></div>
        {%- endif -%}
        <figcaption class="rab__photo-caption">— {{ section.settings.collage_caption_2 | default: 'мигът' }}</figcaption>
      </figure>

      <figure class="rab__collage-item rab__collage-item--c">
        {%- if section.settings.collage_image_3 != blank -%}
          {{ section.settings.collage_image_3 | image_url: width: 1200 | image_tag: class: 'rab__collage-image', sizes: '50vw', widths: '500,800,1200', loading: 'lazy' }}
        {%- else -%}
          <div class="rab__collage-image rab__collage-image--placeholder"></div>
        {%- endif -%}
        <figcaption class="rab__photo-caption rab__photo-caption--bottom-right">— {{ section.settings.collage_caption_3 | default: 'рибата' }}</figcaption>
      </figure>

      <figure class="rab__collage-item rab__collage-item--d">
        {%- if section.settings.collage_image_4 != blank -%}
          {{ section.settings.collage_image_4 | image_url: width: 800 | image_tag: class: 'rab__collage-image', sizes: '25vw', widths: '300,500,800', loading: 'lazy' }}
        {%- else -%}
          <div class="rab__collage-image rab__collage-image--placeholder"></div>
        {%- endif -%}
        <figcaption class="rab__photo-caption">— {{ section.settings.collage_caption_4 | default: 'детайлът' }}</figcaption>
      </figure>

      <figure class="rab__collage-item rab__collage-item--e">
        {%- if section.settings.collage_image_5 != blank -%}
          {{ section.settings.collage_image_5 | image_url: width: 800 | image_tag: class: 'rab__collage-image', sizes: '25vw', widths: '300,500,800', loading: 'lazy' }}
        {%- else -%}
          <div class="rab__collage-image rab__collage-image--placeholder"></div>
        {%- endif -%}
        <figcaption class="rab__photo-caption rab__photo-caption--bottom-right">— {{ section.settings.collage_caption_5 | default: 'ароматът' }}</figcaption>
      </figure>
    </div>
  </section>

  {%- comment -%} ============ Video ============ {%- endcomment -%}
  <section class="rab__video">
    <div class="rab__video-header">
      <span class="rab__kicker rab__kicker--centered">
        <span class="rab__kicker-num">№03</span>
        <span class="rab__kicker-line"></span>
        <span class="rab__kicker-text">{{ section.settings.video_kicker | default: 'ВЛЕЗ В НАШИЯ СВЯТ' }}</span>
        <span class="rab__kicker-line"></span>
      </span>
      <h2 class="rab__video-heading">
        {{ section.settings.video_line_1 | default: 'Кухнята е' }}
        <em>{{ section.settings.video_line_1_em | default: 'сцена.' }}</em><br>
        {{ section.settings.video_line_2 | default: 'Готвачът е' }}
        <em>{{ section.settings.video_line_2_em | default: 'артистът.' }}</em>
      </h2>
    </div>

    <div class="rab__video-frame">
      {%- if section.settings.video != blank -%}
        {{ section.settings.video
          | video_tag:
            controls: true,
            autoplay: false,
            loop: false,
            muted: false,
            class: 'rab__video-media'
        }}
      {%- elsif section.settings.video_url != blank -%}
        <div class="rab__video-embed">
          {{ section.settings.video_url | external_video_tag: class: 'rab__video-media' }}
        </div>
      {%- else -%}
        <div class="rab__video-placeholder">
          {%- if section.settings.video_poster != blank -%}
            {{ section.settings.video_poster | image_url: width: 1800 | image_tag: class: 'rab__video-poster', sizes: '100vw', widths: '600,1200,1800', loading: 'lazy' }}
          {%- endif -%}
          <span class="rab__video-play" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><polygon points="8,5 19,12 8,19"/></svg>
          </span>
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.video_caption != blank -%}
      <p class="rab__video-caption">— {{ section.settings.video_caption }}</p>
    {%- endif -%}
  </section>

  {%- comment -%} ============ Principles (Roman numerals) ============ {%- endcomment -%}
  <section class="rab__principles">
    <div class="rab__principles-header">
      <span class="rab__kicker">
        <span class="rab__kicker-num">№04</span>
        <span class="rab__kicker-line"></span>
        <span class="rab__kicker-text">{{ section.settings.principles_kicker | default: 'НАШИТЕ ПРИНЦИПИ' }}</span>
      </span>
      <h2 class="rab__principles-heading">
        {{ section.settings.principles_line_1 | default: 'Три неща,' }}<br>
        {{ section.settings.principles_line_2 | default: 'които ни' }}
        <em>{{ section.settings.principles_line_2_em | default: 'водят.' }}</em>
      </h2>
    </div>

    <div class="rab__principles-grid">
      <article class="rab__principle">
        <span class="rab__roman" aria-hidden="true">I</span>
        <div class="rab__principle-body">
          <h3 class="rab__principle-title">{{ section.settings.p1_title | default: 'Свежи съставки' }}</h3>
          <p class="rab__principle-text">{{ section.settings.p1_text | default: 'Рибата идва ежедневно. Зеленчуците — от локални производители. Без компромиси.' }}</p>
        </div>
      </article>

      <article class="rab__principle">
        <span class="rab__roman" aria-hidden="true">II</span>
        <div class="rab__principle-body">
          <h3 class="rab__principle-title">{{ section.settings.p2_title | default: 'Майстори в занаята' }}</h3>
          <p class="rab__principle-text">{{ section.settings.p2_text | default: 'Готвачите ни се обучават години, за да достигнат прецизността на японското суши.' }}</p>
        </div>
      </article>

      <article class="rab__principle">
        <span class="rab__roman" aria-hidden="true">III</span>
        <div class="rab__principle-body">
          <h3 class="rab__principle-title">{{ section.settings.p3_title | default: 'Уют и гостоприемство' }}</h3>
          <p class="rab__principle-text">{{ section.settings.p3_text | default: 'От топлото посрещане до последната хапка — всеки детайл е обмислен.' }}</p>
        </div>
      </article>
    </div>
  </section>

  {%- comment -%} ============ Chef Pull Quote ============ {%- endcomment -%}
  <section class="rab__quote">
    <div class="rab__quote-media">
      {%- if section.settings.quote_image != blank -%}
        {{ section.settings.quote_image
          | image_url: width: 2400
          | image_tag:
            class: 'rab__quote-image',
            sizes: '100vw',
            widths: '800,1200,1800,2400',
            loading: 'lazy'
        }}
      {%- endif -%}
      <div class="rab__quote-overlay"></div>
    </div>

    <div class="rab__quote-content">
      <span class="rab__quote-mark" aria-hidden="true">"</span>
      <blockquote class="rab__quote-text">
        {{ section.settings.quote_text | default: 'Сушито не е просто храна — то е <em>разказ.</em> И всеки път, когато режа парче риба, мисля за човека, който ще го опита.' }}
      </blockquote>
      <span class="rab__quote-attr">
        <span class="rab__quote-name">{{ section.settings.quote_name | default: 'ШЕФ КОДЗИ ТАНАКА' }}</span>
        <span class="rab__quote-role">— {{ section.settings.quote_role | default: 'Главен суши майстор' }}</span>
      </span>
    </div>
  </section>

  {%- comment -%} ============ Strip ============ {%- endcomment -%}
  <div class="rab__strip" aria-hidden="true">
    <div class="rab__strip-cell">
      {%- if section.settings.strip_image_1 != blank -%}
        {{ section.settings.strip_image_1 | image_url: width: 700 | image_tag: class: 'rab__strip-image', sizes: '25vw', widths: '300,500,700', loading: 'lazy' }}
      {%- else -%}
        <div class="rab__strip-image rab__strip-image--placeholder"></div>
      {%- endif -%}
    </div>
    <div class="rab__strip-cell">
      {%- if section.settings.strip_image_2 != blank -%}
        {{ section.settings.strip_image_2 | image_url: width: 700 | image_tag: class: 'rab__strip-image', sizes: '25vw', widths: '300,500,700', loading: 'lazy' }}
      {%- else -%}
        <div class="rab__strip-image rab__strip-image--placeholder"></div>
      {%- endif -%}
    </div>
    <div class="rab__strip-cell">
      {%- if section.settings.strip_image_3 != blank -%}
        {{ section.settings.strip_image_3 | image_url: width: 700 | image_tag: class: 'rab__strip-image', sizes: '25vw', widths: '300,500,700', loading: 'lazy' }}
      {%- else -%}
        <div class="rab__strip-image rab__strip-image--placeholder"></div>
      {%- endif -%}
    </div>
    <div class="rab__strip-cell">
      {%- if section.settings.strip_image_4 != blank -%}
        {{ section.settings.strip_image_4 | image_url: width: 700 | image_tag: class: 'rab__strip-image', sizes: '25vw', widths: '300,500,700', loading: 'lazy' }}
      {%- else -%}
        <div class="rab__strip-image rab__strip-image--placeholder"></div>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} ============ Closing Banner ============ {%- endcomment -%}
  <section class="rab__banner">
    {%- if section.settings.banner_image != blank -%}
      {{ section.settings.banner_image
        | image_url: width: 2400
        | image_tag:
          class: 'rab__banner-image',
          sizes: '100vw',
          widths: '900,1300,1700,2400',
          loading: 'lazy'
      }}
    {%- endif -%}
    <div class="rab__banner-overlay"></div>
    <div class="rab__banner-content">
      <h2 class="rab__banner-title">
        {{ section.settings.banner_line_1 | default: 'Създадено' }}
        <em>{{ section.settings.banner_line_1_em | default: 'с любов.' }}</em><br>
        {{ section.settings.banner_line_2 | default: 'Подадено с' }}
        <em>{{ section.settings.banner_line_2_em | default: 'уважение.' }}</em>
      </h2>
      <div class="rab__banner-actions">
        <a href="{{ menu_url }}" class="rab__btn rab__btn--solid">{{ section.settings.banner_cta_primary | default: 'ВИЖ МЕНЮТО' }}</a>
        <a href="{{ contact_url }}" class="rab__btn rab__btn--ghost">{{ section.settings.banner_cta_secondary | default: 'РЕЗЕРВИРАЙ МАСА' }}</a>
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Restaurant About Page",
  "tag": "section",
  "class": "restaurant-about-page-section",
  "enabled_on": { "templates": ["page"] },
  "settings": [
    {
      "type": "header",
      "content": "Hero — main card"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Main image"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Title",
      "default": "За нас"
    },
    {
      "type": "textarea",
      "id": "hero_subtitle",
      "label": "Subtitle",
      "default": "Добре дошли в Суши Бар Манго — място, където свежестта и вкусът се срещат."
    },
    {
      "type": "text",
      "id": "hero_cta_label",
      "label": "CTA label",
      "default": "РАЗБЕРИ ПОВЕЧЕ"
    },
    {
      "type": "url",
      "id": "hero_cta_link",
      "label": "CTA link"
    },
    {
      "type": "header",
      "content": "Hero — side card 1 (Order)"
    },
    { "type": "image_picker", "id": "side1_image", "label": "Image" },
    { "type": "text", "id": "side1_label", "label": "Label", "default": "ПОРЪЧАЙ" },
    { "type": "url", "id": "side1_link", "label": "Link" },
    {
      "type": "header",
      "content": "Hero — side card 2 (Contact)"
    },
