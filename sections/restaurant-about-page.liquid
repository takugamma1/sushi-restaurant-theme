{%- liquid
  assign menu_url = section.settings.menu_url | default: '/pages/menu'
  assign contact_url = section.settings.contact_url | default: '/pages/contact'
  assign marquee_word = section.settings.marquee_word | default: 'MANGO'
-%}

<div class="rab">

  {%- comment -%} ============ Hero (stacked: band + photo) ============ {%- endcomment -%}
  <section class="rab__hero">
    <div class="rab__hero-band">
      <div class="rab__hero-band-inner">
        <h1 class="rab__hero-title">
          {{ section.settings.hero_title_a | default: 'За' }}<em>{{ section.settings.hero_title_em | default: 'нас' }}</em>
        </h1>
        <div class="rab__hero-aside">
          {%- if section.settings.hero_tag != blank -%}
            <span class="rab__hero-eyebrow">
              <span class="rab__hero-eyebrow-mark" aria-hidden="true">◇</span>
              {{ section.settings.hero_tag }}
            </span>
          {%- endif -%}
          {%- if section.settings.hero_subtitle != blank -%}
            <p class="rab__hero-copy">{{ section.settings.hero_subtitle }}</p>
          {%- else -%}
            <p class="rab__hero-copy">Поднасяме широка селекция от прясна риба и японски деликатеси — суши, сашими, рулца и още много вкусове, приготвени ръчно.</p>
          {%- endif -%}
        </div>
      </div>
    </div>

    <div class="rab__hero-photo">
      {%- if section.settings.hero_image != blank -%}
        {{ section.settings.hero_image
          | image_url: width: 2800
          | image_tag:
            class: 'rab__hero-photo-image',
            sizes: '100vw',
            widths: '900,1300,1700,2200,2800',
            loading: 'eager',
            fetchpriority: 'high'
        }}
      {%- else -%}
        <div class="rab__hero-photo-image rab__hero-photo-image--placeholder"></div>
      {%- endif -%}
    </div>
  </section>

  {%- comment -%} ============ Marquee ============ {%- endcomment -%}
  <div class="rab__marquee" aria-hidden="true">
    <div class="rab__marquee-track">
      {%- for i in (1..2) -%}
        {%- for j in (1..6) -%}
          <span class="rab__marquee-word">{{ marquee_word }}</span>
          <span class="rab__marquee-dia">◇</span>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%} ============ Story ============ {%- endcomment -%}
  <section class="rab__story">
    <span class="rab__watermark" aria-hidden="true">{{ section.settings.year | default: '2012' }}</span>

    <div class="rab__story-inner">
      <div class="rab__story-text">
        <span class="rab__kicker">
          <span class="rab__kicker-num">№01</span>
          <span class="rab__kicker-line"></span>
          <span class="rab__kicker-text">{{ section.settings.story_kicker | default: 'НАШАТА ИСТОРИЯ' }}</span>
        </span>

        <h2 class="rab__story-heading">
          {{ section.settings.story_line_1 | default: 'Една кухня,' }}<br>
          {{ section.settings.story_line_2 | default: 'една' }}
          <em>{{ section.settings.story_line_2_em | default: 'страст.' }}</em>
        </h2>

        <p class="rab__story-lead">
          <span class="rab__dropcap">{{ section.settings.dropcap | default: 'М' }}</span>{{ section.settings.story_lead | default: 'анго е родено от любовта към японската традиция и желанието да донесем истинското суши в България. От една малка кухня преди повече от десет години — до място, в което се срещат майсторски нож, прясна риба и съвременна атмосфера.' }}
        </p>

        <p class="rab__story-body">{{ section.settings.story_body | default: 'Всяко рулце е приготвено ръчно — с уважение към продукта и с прецизност, която сме научили от истинските майстори на занаята.' }}</p>

        <div class="rab__story-stats">
          <div class="rab__stat">
            <span class="rab__stat-num">{{ section.settings.stat_1_num | default: '10+' }}</span>
            <span class="rab__stat-label">{{ section.settings.stat_1_label | default: 'години' }}</span>
          </div>
          <div class="rab__stat">
            <span class="rab__stat-num">{{ section.settings.stat_2_num | default: '120' }}</span>
            <span class="rab__stat-label">{{ section.settings.stat_2_label | default: 'ястия' }}</span>
          </div>
          <div class="rab__stat">
            <span class="rab__stat-num">{{ section.settings.stat_3_num | default: '50k+' }}</span>
            <span class="rab__stat-label">{{ section.settings.stat_3_label | default: 'клиенти' }}</span>
          </div>
        </div>
      </div>

      <figure class="rab__story-photo">
        {%- if section.settings.story_image != blank -%}
          {{ section.settings.story_image
            | image_url: width: 1200
            | image_tag:
              class: 'rab__story-image',
              sizes: '(min-width: 990px) 40vw, 80vw',
              widths: '500,800,1100,1400',
              loading: 'lazy'
          }}
        {%- else -%}
          <div class="rab__story-image rab__story-image--placeholder"></div>
        {%- endif -%}
        {%- if section.settings.story_caption != blank -%}
          <figcaption class="rab__photo-caption">— {{ section.settings.story_caption }}</figcaption>
        {%- endif -%}
      </figure>
    </div>
  </section>

  {%- comment -%} ============ Photo Collage ============ {%- endcomment -%}
  <section class="rab__collage">
    <div class="rab__collage-header">
      <span class="rab__kicker">
        <span class="rab__kicker-num">№02</span>
        <span class="rab__kicker-line"></span>
        <span class="rab__kicker-text">{{ section.settings.collage_kicker | default: 'МОМЕНТИ' }}</span>
      </span>
      <h2 class="rab__collage-heading">
        {{ section.settings.collage_line_1 | default: 'Прецизност' }} <em>—</em><br>
        {{ section.settings.collage_line_2 | default: 'хапка по хапка.' }}
      </h2>
    </div>

    {%- comment -%} Only render photos that are actually set, in order, so
       empty slots never leave black gaps. The grid layout adapts to the
       count (5 → tidy bento, 10 → full gallery-style mosaic). {%- endcomment -%}
    {%- liquid
      assign rab_count = 0
      if section.settings.collage_image_1 != blank
        assign rab_count = rab_count | plus: 1
      endif
      if section.settings.collage_image_2 != blank
        assign rab_count = rab_count | plus: 1
      endif
      if section.settings.collage_image_3 != blank
        assign rab_count = rab_count | plus: 1
      endif
      if section.settings.collage_image_4 != blank
        assign rab_count = rab_count | plus: 1
      endif
      if section.settings.collage_image_5 != blank
        assign rab_count = rab_count | plus: 1
      endif
      if section.settings.collage_image_6 != blank
        assign rab_count = rab_count | plus: 1
      endif
      if section.settings.collage_image_7 != blank
        assign rab_count = rab_count | plus: 1
      endif
      if section.settings.collage_image_8 != blank
        assign rab_count = rab_count | plus: 1
      endif
      if section.settings.collage_image_9 != blank
        assign rab_count = rab_count | plus: 1
      endif
      if section.settings.collage_image_10 != blank
        assign rab_count = rab_count | plus: 1
      endif
      assign rab_letters = 'a,b,c,d,e,f,g,h,i,j' | split: ','
      assign rab_i = 0
      assign rab_img_sizes = '(min-width: 990px) 40vw, 100vw'
      assign rab_img_widths = '500,900,1300,1600'
    -%}

    <div class="rab__collage-grid rab__collage-grid--{{ rab_count }}">
      {%- if section.settings.collage_image_1 != blank -%}{%- assign L = rab_letters[rab_i] -%}<figure class="rab__collage-item rab__collage-item--{{ L }}">{{ section.settings.collage_image_1 | image_url: width: 1600 | image_tag: class: 'rab__collage-image', sizes: rab_img_sizes, widths: rab_img_widths, loading: 'lazy' }}{%- if section.settings.collage_caption_1 != blank -%}<figcaption class="rab__collage-caption">— {{ section.settings.collage_caption_1 }}</figcaption>{%- endif -%}</figure>{%- assign rab_i = rab_i | plus: 1 -%}{%- endif -%}
      {%- if section.settings.collage_image_2 != blank -%}{%- assign L = rab_letters[rab_i] -%}<figure class="rab__collage-item rab__collage-item--{{ L }}">{{ section.settings.collage_image_2 | image_url: width: 1600 | image_tag: class: 'rab__collage-image', sizes: rab_img_sizes, widths: rab_img_widths, loading: 'lazy' }}{%- if section.settings.collage_caption_2 != blank -%}<figcaption class="rab__collage-caption">— {{ section.settings.collage_caption_2 }}</figcaption>{%- endif -%}</figure>{%- assign rab_i = rab_i | plus: 1 -%}{%- endif -%}
      {%- if section.settings.collage_image_3 != blank -%}{%- assign L = rab_letters[rab_i] -%}<figure class="rab__collage-item rab__collage-item--{{ L }}">{{ section.settings.collage_image_3 | image_url: width: 1600 | image_tag: class: 'rab__collage-image', sizes: rab_img_sizes, widths: rab_img_widths, loading: 'lazy' }}{%- if section.settings.collage_caption_3 != blank -%}<figcaption class="rab__collage-caption">— {{ section.settings.collage_caption_3 }}</figcaption>{%- endif -%}</figure>{%- assign rab_i = rab_i | plus: 1 -%}{%- endif -%}
      {%- if section.settings.collage_image_4 != blank -%}{%- assign L = rab_letters[rab_i] -%}<figure class="rab__collage-item rab__collage-item--{{ L }}">{{ section.settings.collage_image_4 | image_url: width: 1600 | image_tag: class: 'rab__collage-image', sizes: rab_img_sizes, widths: rab_img_widths, loading: 'lazy' }}{%- if section.settings.collage_caption_4 != blank -%}<figcaption class="rab__collage-caption">— {{ section.settings.collage_caption_4 }}</figcaption>{%- endif -%}</figure>{%- assign rab_i = rab_i | plus: 1 -%}{%- endif -%}
      {%- if section.settings.collage_image_5 != blank -%}{%- assign L = rab_letters[rab_i] -%}<figure class="rab__collage-item rab__collage-item--{{ L }}">{{ section.settings.collage_image_5 | image_url: width: 1600 | image_tag: class: 'rab__collage-image', sizes: rab_img_sizes, widths: rab_img_widths, loading: 'lazy' }}{%- if section.settings.collage_caption_5 != blank -%}<figcaption class="rab__collage-caption">— {{ section.settings.collage_caption_5 }}</figcaption>{%- endif -%}</figure>{%- assign rab_i = rab_i | plus: 1 -%}{%- endif -%}
      {%- if section.settings.collage_image_6 != blank -%}{%- assign L = rab_letters[rab_i] -%}<figure class="rab__collage-item rab__collage-item--{{ L }}">{{ section.settings.collage_image_6 | image_url: width: 1600 | image_tag: class: 'rab__collage-image', sizes: rab_img_sizes, widths: rab_img_widths, loading: 'lazy' }}{%- if section.settings.collage_caption_6 != blank -%}<figcaption class="rab__collage-caption">— {{ section.settings.collage_caption_6 }}</figcaption>{%- endif -%}</figure>{%- assign rab_i = rab_i | plus: 1 -%}{%- endif -%}
      {%- if section.settings.collage_image_7 != blank -%}{%- assign L = rab_letters[rab_i] -%}<figure class="rab__collage-item rab__collage-item--{{ L }}">{{ section.settings.collage_image_7 | image_url: width: 1600 | image_tag: class: 'rab__collage-image', sizes: rab_img_sizes, widths: rab_img_widths, loading: 'lazy' }}{%- if section.settings.collage_caption_7 != blank -%}<figcaption class="rab__collage-caption">— {{ section.settings.collage_caption_7 }}</figcaption>{%- endif -%}</figure>{%- assign rab_i = rab_i | plus: 1 -%}{%- endif -%}
      {%- if section.settings.collage_image_8 != blank -%}{%- assign L = rab_letters[rab_i] -%}<figure class="rab__collage-item rab__collage-item--{{ L }}">{{ section.settings.collage_image_8 | image_url: width: 1600 | image_tag: class: 'rab__collage-image', sizes: rab_img_sizes, widths: rab_img_widths, loading: 'lazy' }}{%- if section.settings.collage_caption_8 != blank -%}<figcaption class="rab__collage-caption">— {{ section.settings.collage_caption_8 }}</figcaption>{%- endif -%}</figure>{%- assign rab_i = rab_i | plus: 1 -%}{%- endif -%}
      {%- if section.settings.collage_image_9 != blank -%}{%- assign L = rab_letters[rab_i] -%}<figure class="rab__collage-item rab__collage-item--{{ L }}">{{ section.settings.collage_image_9 | image_url: width: 1600 | image_tag: class: 'rab__collage-image', sizes: rab_img_sizes, widths: rab_img_widths, loading: 'lazy' }}{%- if section.settings.collage_caption_9 != blank -%}<figcaption class="rab__collage-caption">— {{ section.settings.collage_caption_9 }}</figcaption>{%- endif -%}</figure>{%- assign rab_i = rab_i | plus: 1 -%}{%- endif -%}
      {%- if section.settings.collage_image_10 != blank -%}{%- assign L = rab_letters[rab_i] -%}<figure class="rab__collage-item rab__collage-item--{{ L }}">{{ section.settings.collage_image_10 | image_url: width: 1600 | image_tag: class: 'rab__collage-image', sizes: rab_img_sizes, widths: rab_img_widths, loading: 'lazy' }}{%- if section.settings.collage_caption_10 != blank -%}<figcaption class="rab__collage-caption">— {{ section.settings.collage_caption_10 }}</figcaption>{%- endif -%}</figure>{%- assign rab_i = rab_i | plus: 1 -%}{%- endif -%}
    </div>
  </section>

  {%- comment -%} ============ Video ============ {%- endcomment -%}
  <section class="rab__video">
    <div class="rab__video-header">
      <span class="rab__kicker rab__kicker--centered">
        <span class="rab__kicker-num">№03</span>
        <span class="rab__kicker-line"></span>
        <span class="rab__kicker-text">{{ section.settings.video_kicker | default: 'ВЛЕЗ В НАШИЯ СВЯТ' }}</span>
        <span class="rab__kicker-line"></span>
      </span>
      <h2 class="rab__video-heading">
        {{ section.settings.video_line_1 | default: 'Кухнята е' }}
        <em>{{ section.settings.video_line_1_em | default: 'сцена.' }}</em><br>
        {{ section.settings.video_line_2 | default: 'Готвачът е' }}
        <em>{{ section.settings.video_line_2_em | default: 'артистът.' }}</em>
      </h2>
    </div>

    {%- liquid
      assign has_video = false
      if section.settings.video_file_url != blank or section.settings.video != blank or section.settings.video_url != blank
        assign has_video = true
      endif
    -%}
    {%- capture rab_player_markup -%}
      {%- if section.settings.video_file_url != blank -%}
        {%- comment -%} Direct file URL (e.g. Shopify Content → Files CDN) — lazy, only fetched on click {%- endcomment -%}
        <video class="rab__video-media" controls autoplay playsinline preload="auto"{% if section.settings.video_poster != blank %} poster="{{ section.settings.video_poster | image_url: width: 1800 }}"{% endif %}>
          <source src="{{ section.settings.video_file_url }}" type="video/mp4">
        </video>
      {%- elsif section.settings.video != blank -%}
        {{ section.settings.video | video_tag: controls: true, autoplay: true, loop: false, muted: false, playsinline: true, class: 'rab__video-media' }}
      {%- else -%}
        <div class="rab__video-embed">
          {{ section.settings.video_url | external_video_tag: class: 'rab__video-media', autoplay: true }}
        </div>
      {%- endif -%}
    {%- endcapture -%}
    <div class="rab__video-frame">
      {%- if has_video -%}
        {%- comment -%} Always click-to-play in the lightbox pop-up (poster optional;
           a dark frame + play button is shown when no poster is set). {%- endcomment -%}
        <div class="rab__video-placeholder" data-rab-poster>
          {%- if section.settings.video_poster != blank -%}
            {{ section.settings.video_poster | image_url: width: 1800 | image_tag: class: 'rab__video-poster', sizes: '100vw', widths: '600,1200,1800', loading: 'lazy' }}
          {%- endif -%}
          <button type="button" class="rab__video-play" data-rab-play aria-label="Пусни видеото">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><polygon points="8,5 19,12 8,19"/></svg>
          </button>
        </div>
        <template data-rab-player>{{ rab_player_markup }}</template>
      {%- elsif section.settings.video_poster != blank -%}
        {%- comment -%} Only a poster, no video configured — just the image {%- endcomment -%}
        <div class="rab__video-placeholder">
          {{ section.settings.video_poster | image_url: width: 1800 | image_tag: class: 'rab__video-poster', sizes: '100vw', widths: '600,1200,1800', loading: 'lazy' }}
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.video_caption != blank -%}
      <p class="rab__video-caption">— {{ section.settings.video_caption }}</p>
    {%- endif -%}
  </section>

  {%- comment -%} ============ Principles (Roman numerals) ============ {%- endcomment -%}
  <section class="rab__principles">
    <div class="rab__principles-header">
      <span class="rab__kicker">
        <span class="rab__kicker-num">№04</span>
        <span class="rab__kicker-line"></span>
        <span class="rab__kicker-text">{{ section.settings.principles_kicker | default: 'НАШИТЕ ПРИНЦИПИ' }}</span>
      </span>
      <h2 class="rab__principles-heading">
        {{ section.settings.principles_line_1 | default: 'Три неща,' }}<br>
        {{ section.settings.principles_line_2 | default: 'които ни' }}
        <em>{{ section.settings.principles_line_2_em | default: 'водят.' }}</em>
      </h2>
    </div>

    <div class="rab__principles-grid">
      <article class="rab__principle">
        <span class="rab__roman" aria-hidden="true">I</span>
        <div class="rab__principle-body">
          <h3 class="rab__principle-title">{{ section.settings.p1_title | default: 'Свежи съставки' }}</h3>
          <p class="rab__principle-text">{{ section.settings.p1_text | default: 'Рибата идва ежедневно. Зеленчуците — от локални производители. Без компромиси.' }}</p>
        </div>
      </article>

      <article class="rab__principle">
        <span class="rab__roman" aria-hidden="true">II</span>
        <div class="rab__principle-body">
          <h3 class="rab__principle-title">{{ section.settings.p2_title | default: 'Майстори в занаята' }}</h3>
          <p class="rab__principle-text">{{ section.settings.p2_text | default: 'Готвачите ни се обучават години, за да достигнат прецизността на японското суши.' }}</p>
        </div>
      </article>

      <article class="rab__principle">
        <span class="rab__roman" aria-hidden="true">III</span>
        <div class="rab__principle-body">
          <h3 class="rab__principle-title">{{ section.settings.p3_title | default: 'Уют и гостоприемство' }}</h3>
          <p class="rab__principle-text">{{ section.settings.p3_text | default: 'От топлото посрещане до последната хапка — всеки детайл е обмислен.' }}</p>
        </div>
      </article>
    </div>
  </section>

  {%- comment -%} ============ Chef Pull Quote ============ {%- endcomment -%}
  <section class="rab__quote">
    <div class="rab__quote-media">
      {%- if section.settings.quote_image != blank -%}
        {{ section.settings.quote_image
          | image_url: width: 2400
          | image_tag:
            class: 'rab__quote-image',
            sizes: '100vw',
            widths: '800,1200,1800,2400',
            loading: 'lazy'
        }}
      {%- endif -%}
      <div class="rab__quote-overlay"></div>
    </div>

    <div class="rab__quote-content">
      <span class="rab__quote-mark" aria-hidden="true">"</span>
      <blockquote class="rab__quote-text">
        {{ section.settings.quote_text | default: 'Сушито не е просто храна — то е <em>разказ.</em> И всеки път, когато режа парче риба, мисля за човека, който ще го опита.' }}
      </blockquote>
      <span class="rab__quote-attr">
        <span class="rab__quote-name">{{ section.settings.quote_name | default: 'ШЕФ КОДЗИ ТАНАКА' }}</span>
        <span class="rab__quote-role">— {{ section.settings.quote_role | default: 'Главен суши майстор' }}</span>
      </span>
    </div>
  </section>

  {%- comment -%} ============ Strip ============ {%- endcomment -%}
  <div class="rab__strip" aria-hidden="true">
    <div class="rab__strip-cell">
      {%- if section.settings.strip_image_1 != blank -%}
        {{ section.settings.strip_image_1 | image_url: width: 700 | image_tag: class: 'rab__strip-image', sizes: '25vw', widths: '300,500,700', loading: 'lazy' }}
      {%- else -%}
        <div class="rab__strip-image rab__strip-image--placeholder"></div>
      {%- endif -%}
    </div>
    <div class="rab__strip-cell">
      {%- if section.settings.strip_image_2 != blank -%}
        {{ section.settings.strip_image_2 | image_url: width: 700 | image_tag: class: 'rab__strip-image', sizes: '25vw', widths: '300,500,700', loading: 'lazy' }}
      {%- else -%}
        <div class="rab__strip-image rab__strip-image--placeholder"></div>
      {%- endif -%}
    </div>
    <div class="rab__strip-cell">
      {%- if section.settings.strip_image_3 != blank -%}
        {{ section.settings.strip_image_3 | image_url: width: 700 | image_tag: class: 'rab__strip-image', sizes: '25vw', widths: '300,500,700', loading: 'lazy' }}
      {%- else -%}
        <div class="rab__strip-image rab__strip-image--placeholder"></div>
      {%- endif -%}
    </div>
    <div class="rab__strip-cell">
      {%- if section.settings.strip_image_4 != blank -%}
        {{ section.settings.strip_image_4 | image_url: width: 700 | image_tag: class: 'rab__strip-image', sizes: '25vw', widths: '300,500,700', loading: 'lazy' }}
      {%- else -%}
        <div class="rab__strip-image rab__strip-image--placeholder"></div>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} ============ Closing Banner ============ {%- endcomment -%}
  <section class="rab__banner">
    {%- if section.settings.banner_image != blank -%}
      {{ section.settings.banner_image
        | image_url: width: 2400
        | image_tag:
          class: 'rab__banner-image',
          sizes: '100vw',
          widths: '900,1300,1700,2400',
          loading: 'lazy'
      }}
    {%- endif -%}
    <div class="rab__banner-overlay"></div>
    <div class="rab__banner-content">
      <h2 class="rab__banner-title">
        {{ section.settings.banner_line_1 | default: 'Създадено' }}
        <em>{{ section.settings.banner_line_1_em | default: 'с любов.' }}</em><br>
        {{ section.settings.banner_line_2 | default: 'Подадено с' }}
        <em>{{ section.settings.banner_line_2_em | default: 'уважение.' }}</em>
      </h2>
      <div class="rab__banner-actions">
        <a href="{{ menu_url }}" class="rab__btn rab__btn--solid">{{ section.settings.banner_cta_primary | default: 'ВИЖ МЕНЮТО' }}</a>
        <a href="{{ contact_url }}" class="rab__btn rab__btn--ghost">{{ section.settings.banner_cta_secondary | default: 'РЕЗЕРВИРАЙ МАСА' }}</a>
      </div>
    </div>
  </section>
</div>

<script>
  (function () {
    // Video poster -> open the player in a closable lightbox pop-up.
    var vModal = null;

    function buildVideoModal() {
      if (vModal) return vModal;
      vModal = document.createElement('div');
      vModal.className = 'rab__vmodal';
      vModal.setAttribute('aria-hidden', 'true');
      vModal.innerHTML =
        '<div class="rab__vmodal__backdrop" data-vmodal-close></div>' +
        '<button type="button" class="rab__vmodal__close" data-vmodal-close aria-label="Затвори">' +
          '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>' +
        '</button>' +
        '<div class="rab__vmodal__dialog"><div class="rab__vmodal__stage" data-vmodal-stage></div></div>';
      document.body.appendChild(vModal);
      vModal.querySelectorAll('[data-vmodal-close]').forEach(function (el) {
        el.addEventListener('click', closeVideoModal);
      });
      return vModal;
    }

    function openVideoModal(tpl) {
      var m = buildVideoModal();
      var stage = m.querySelector('[data-vmodal-stage]');
      stage.innerHTML = '';
      var clone = tpl.content.cloneNode(true);
      var vid = clone.querySelector('video');
      stage.appendChild(clone);
      document.body.style.overflow = 'hidden';
      m.setAttribute('aria-hidden', 'false');
      requestAnimationFrame(function () { m.classList.add('is-open'); });
      // Start inside the user gesture so audio is allowed.
      if (vid && typeof vid.play === 'function') { vid.play().catch(function () {}); }
    }

    function closeVideoModal() {
      if (!vModal) return;
      vModal.classList.remove('is-open');
      vModal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      // Clearing the stage stops playback (video + YouTube/Vimeo iframe alike).
      var stage = vModal.querySelector('[data-vmodal-stage]');
      if (stage) stage.innerHTML = '';
    }

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && vModal && vModal.classList.contains('is-open')) closeVideoModal();
    });

    document.querySelectorAll('[data-rab-play]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var poster = btn.closest('[data-rab-poster]');
        var frame = poster && poster.parentElement;
        var tpl = frame && frame.querySelector('[data-rab-player]');
        if (!tpl) return;
        openVideoModal(tpl);
      });
    });

    // Collage: same staggered scroll-fade as the Gallery page
    var grid = document.querySelector('.rab__collage-grid');
    if (!grid) return;
    var cells = grid.querySelectorAll('.rab__collage-item');
    var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var mobile = window.matchMedia('(max-width: 749px)').matches;
    var stagger = mobile ? 40 : 80;
    cells.forEach(function (c, i) { c.style.setProperty('--rab-delay', (i * stagger) + 'ms'); });

    if (reduced || !('IntersectionObserver' in window)) {
      cells.forEach(function (c) { c.classList.add('is-visible'); });
      return;
    }

    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) { e.target.classList.toggle('is-visible', e.isIntersecting); });
    }, { threshold: 0.12, rootMargin: mobile ? '0px 0px -8% 0px' : '0px 0px -12% 0px' });

    cells.forEach(function (c) { io.observe(c); });
  })();
</script>

