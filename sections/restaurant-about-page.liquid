{%- liquid
  assign menu_url = section.settings.menu_url | default: '/pages/menu'
  assign contact_url = section.settings.contact_url | default: '/pages/contact'
-%}

<div class="rab">

  {%- comment -%} ============ Hero ============ {%- endcomment -%}
  <section class="rab__hero">
    <div class="rab__hero-media">
      {%- if section.settings.hero_image != blank -%}
        {{ section.settings.hero_image
          | image_url: width: 2800
          | image_tag:
            class: 'rab__hero-image',
            sizes: '100vw',
            widths: '800,1200,1600,2200,2800',
            loading: 'eager',
            fetchpriority: 'high'
        }}
      {%- else -%}
        <div class="rab__hero-image rab__hero-image--placeholder"></div>
      {%- endif -%}
      <div class="rab__hero-overlay"></div>
    </div>

    <div class="rab__hero-content">
      {%- if section.settings.hero_tagline != blank -%}
        <span class="rab__hero-tagline">{{ section.settings.hero_tagline }}</span>
      {%- endif -%}
      <h1 class="rab__hero-title">{{ section.settings.hero_title | default: 'Опитай<br>повече' }}</h1>
      {%- if section.settings.hero_cta_label != blank -%}
        <a href="{{ menu_url }}" class="rab__hero-cta">
          <span>{{ section.settings.hero_cta_label }}</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      {%- endif -%}
    </div>
  </section>

  {%- comment -%} ============ Our Menu (white, images left) ============ {%- endcomment -%}
  <section class="rab__split rab__split--light rab__split--images-left">
    <div class="rab__split-inner">
      <div class="rab__pair">
        <div class="rab__pair-main">
          {%- if section.settings.menu_image_1 != blank -%}
            {{ section.settings.menu_image_1
              | image_url: width: 1400
              | image_tag:
                class: 'rab__pair-image',
                sizes: '(min-width: 990px) 35vw, 70vw',
                widths: '500,800,1100,1400',
                loading: 'lazy'
            }}
          {%- else -%}
            <div class="rab__pair-image rab__pair-image--placeholder"></div>
          {%- endif -%}
        </div>
        <div class="rab__pair-overlap">
          {%- if section.settings.menu_image_2 != blank -%}
            {{ section.settings.menu_image_2
              | image_url: width: 900
              | image_tag:
                class: 'rab__pair-image',
                sizes: '(min-width: 990px) 22vw, 45vw',
                widths: '400,600,900',
                loading: 'lazy'
            }}
          {%- else -%}
            <div class="rab__pair-image rab__pair-image--placeholder"></div>
          {%- endif -%}
        </div>
      </div>

      <div class="rab__copy">
        <span class="rab__kicker rab__kicker--dark">
          <span class="rab__kicker-diamond" aria-hidden="true">◇</span>
          {{ section.settings.menu_kicker | default: 'НАШЕТО МЕНЮ' }}
        </span>
        <h2 class="rab__copy-title rab__copy-title--dark">
          {{ section.settings.menu_title | default: 'Вкусове, които пътуват от Япония до твоята маса' }}
        </h2>
        <p class="rab__copy-text rab__copy-text--dark">
          {{ section.settings.menu_text | default: 'Драги приятели! Добре дошли в Mango. Всяко ястие е приготвено със страст и поднесено в най-добрите традиции на японската кухня. Луксозна селекция от напитки. Тук можеш да научиш повече за нашето меню.' }}
        </p>
        <a href="{{ menu_url }}" class="rab__btn rab__btn--ghost-dark">
          {{ section.settings.menu_cta_label | default: 'МЕНЮ' }}
        </a>
      </div>
    </div>
  </section>

  {%- comment -%} ============ Our Story (dark, text left, images right) ============ {%- endcomment -%}
  <section class="rab__split rab__split--dark rab__split--images-right">
    <div class="rab__split-inner">
      <div class="rab__copy">
        <span class="rab__kicker rab__kicker--light">
          <span class="rab__kicker-diamond" aria-hidden="true">◇</span>
          {{ section.settings.story_kicker | default: 'НАШАТА ИСТОРИЯ' }}
        </span>
        <h2 class="rab__copy-title rab__copy-title--light">
          {{ section.settings.story_title | default: 'Една кухня, една страст, едно десетилетие' }}
        </h2>
        <p class="rab__copy-text rab__copy-text--light">
          {{ section.settings.story_text | default: 'Mango е родено от любовта към японската традиция и желанието да донесем истинското суши в България. От една малка кухня преди повече от десет години — до място, в което се срещат майсторски нож, прясна риба и съвременна атмосфера.' }}
        </p>
        <p class="rab__copy-text rab__copy-text--light">
          {{ section.settings.story_text_2 | default: 'Всяко рулце е приготвено ръчно — с уважение към продукта и с прецизност, която сме научили от истинските майстори на занаята.' }}
        </p>
        <a href="{{ menu_url }}" class="rab__btn rab__btn--ghost-light">
          {{ section.settings.story_cta_label | default: 'ВИЖ МЕНЮТО' }}
        </a>
      </div>

      <div class="rab__pair rab__pair--reverse">
        <div class="rab__pair-main">
          {%- if section.settings.story_image_1 != blank -%}
            {{ section.settings.story_image_1
              | image_url: width: 1400
              | image_tag:
                class: 'rab__pair-image',
                sizes: '(min-width: 990px) 35vw, 70vw',
                widths: '500,800,1100,1400',
                loading: 'lazy'
            }}
          {%- else -%}
            <div class="rab__pair-image rab__pair-image--placeholder"></div>
          {%- endif -%}
        </div>
        <div class="rab__pair-overlap">
          {%- if section.settings.story_image_2 != blank -%}
            {{ section.settings.story_image_2
              | image_url: width: 900
              | image_tag:
                class: 'rab__pair-image',
                sizes: '(min-width: 990px) 22vw, 45vw',
                widths: '400,600,900',
                loading: 'lazy'
            }}
          {%- else -%}
            <div class="rab__pair-image rab__pair-image--placeholder"></div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ============ Our Interior (white, images left) ============ {%- endcomment -%}
  <section class="rab__split rab__split--light rab__split--images-left">
    <div class="rab__split-inner">
      <div class="rab__pair">
        <div class="rab__pair-main">
          {%- if section.settings.interior_image_1 != blank -%}
            {{ section.settings.interior_image_1
              | image_url: width: 1400
              | image_tag:
                class: 'rab__pair-image',
                sizes: '(min-width: 990px) 35vw, 70vw',
                widths: '500,800,1100,1400',
                loading: 'lazy'
            }}
          {%- else -%}
            <div class="rab__pair-image rab__pair-image--placeholder"></div>
          {%- endif -%}
        </div>
        <div class="rab__pair-overlap">
          {%- if section.settings.interior_image_2 != blank -%}
            {{ section.settings.interior_image_2
              | image_url: width: 900
              | image_tag:
                class: 'rab__pair-image',
                sizes: '(min-width: 990px) 22vw, 45vw',
                widths: '400,600,900',
                loading: 'lazy'
            }}
          {%- else -%}
            <div class="rab__pair-image rab__pair-image--placeholder"></div>
          {%- endif -%}
        </div>
      </div>

      <div class="rab__copy">
        <span class="rab__kicker rab__kicker--dark">
          <span class="rab__kicker-diamond" aria-hidden="true">◇</span>
          {{ section.settings.interior_kicker | default: 'НАШИЯТ ИНТЕРИОР' }}
        </span>
        <h2 class="rab__copy-title rab__copy-title--dark">
          {{ section.settings.interior_title | default: 'Място, в което всеки детайл е обмислен' }}
        </h2>
        <p class="rab__copy-text rab__copy-text--dark">
          {{ section.settings.interior_text | default: 'Нашият ресторант разполага с две зали — голяма светла зала с панорамни прозорци и зала в тъмни тонове. Тук можеш да събереш голяма компания или да прекараш интимна вечер.' }}
        </p>
        <p class="rab__copy-text rab__copy-text--dark">
          {{ section.settings.interior_text_2 | default: 'Искрено се надяваме да се насладиш на посещението при нас.' }}
        </p>
        <a href="{{ contact_url }}" class="rab__btn rab__btn--ghost-dark">
          {{ section.settings.interior_cta_label | default: 'РЕЗЕРВАЦИЯ' }}
        </a>
      </div>
    </div>
  </section>

  {%- comment -%} ============ Closing Banner ============ {%- endcomment -%}
  <section class="rab__banner">
    {%- if section.settings.banner_image != blank -%}
      {{ section.settings.banner_image
        | image_url: width: 2400
        | image_tag:
          class: 'rab__banner-image',
          sizes: '100vw',
          widths: '900,1300,1700,2400',
          loading: 'lazy'
      }}
    {%- endif -%}
    <div class="rab__banner-overlay"></div>
    <div class="rab__banner-content">
      <h2 class="rab__banner-title">
        {{ section.settings.banner_title | default: 'Създадено<br>с любов.' }}
      </h2>
      <div class="rab__banner-actions">
        <a href="{{ menu_url }}" class="rab__btn rab__btn--solid">
          {{ section.settings.banner_cta_primary | default: 'ВИЖ МЕНЮТО' }}
        </a>
        <a href="{{ contact_url }}" class="rab__btn rab__btn--ghost-light">
          {{ section.settings.banner_cta_secondary | default: 'РЕЗЕРВИРАЙ МАСА' }}
        </a>
      </div>
    </div>
  </section>
</div>

