{%- liquid
  assign menu_url = section.settings.menu_url | default: '/pages/menu'
  assign contact_url = section.settings.contact_url | default: '/pages/contact'
-%}

<div class="rab">

  {%- comment -%} ============ Hero ============ {%- endcomment -%}
  <section class="rab__hero">
    <div class="rab__hero-media">
      {%- if section.settings.hero_image != blank -%}
        {{ section.settings.hero_image
          | image_url: width: 2800
          | image_tag:
            class: 'rab__hero-image',
            sizes: '100vw',
            widths: '800,1200,1600,2200,2800',
            loading: 'eager',
            fetchpriority: 'high'
        }}
      {%- else -%}
        <div class="rab__hero-image rab__hero-image--placeholder"></div>
      {%- endif -%}
      <div class="rab__hero-overlay"></div>
    </div>

    <div class="rab__hero-content">
      <div class="rab__eyebrow rab__eyebrow--light">
        <span class="rab__eyebrow-line"></span>
        <span class="rab__eyebrow-diamond">◇</span>
        <span class="rab__eyebrow-text">{{ section.settings.hero_eyebrow | default: 'НАШАТА ИСТОРИЯ' }}</span>
        <span class="rab__eyebrow-diamond">◇</span>
        <span class="rab__eyebrow-line"></span>
      </div>
      <h1 class="rab__hero-title">{{ section.settings.hero_title | default: 'ЗА НАС' }}</h1>
      {%- if section.settings.hero_subtitle != blank -%}
        <p class="rab__hero-subtitle">{{ section.settings.hero_subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="rab__scroll-cue" aria-hidden="true">
      <span class="rab__scroll-cue-line"></span>
    </div>
  </section>

  {%- comment -%} ============ Story (white) ============ {%- endcomment -%}
  <section class="rab__story">
    <div class="rab__story-inner">
      <div class="rab__story-media">
        {%- if section.settings.story_image != blank -%}
          {{ section.settings.story_image
            | image_url: width: 1600
            | image_tag:
              class: 'rab__story-image',
              sizes: '(min-width: 990px) 45vw, 100vw',
              widths: '600,900,1200,1600',
              loading: 'lazy'
          }}
        {%- endif -%}
        <span class="rab__story-tag">EST. {{ section.settings.story_year | default: '2012' }}</span>
      </div>

      <div class="rab__story-body">
        <div class="rab__eyebrow rab__eyebrow--dark">
          <span class="rab__eyebrow-diamond">◇</span>
          <span class="rab__eyebrow-text">{{ section.settings.story_eyebrow | default: 'НАШЕТО НАЧАЛО' }}</span>
          <span class="rab__eyebrow-diamond">◇</span>
        </div>
        <h2 class="rab__story-title">{{ section.settings.story_title | default: 'Страст към автентичното суши' }}</h2>

        <div class="rab__story-rule"><span class="rab__rule-diamond">◇</span></div>

        <div class="rab__story-text rte">
          {{ section.settings.story_text | default: '<p>Манго е родено от любовта към японската традиция и желанието да донесем истинското суши в България. От една малка кухня преди повече от десет години, до място, в което се срещат майсторски нож, прясна риба и съвременна атмосфера.</p><p>Всяко рулце е приготвено ръчно — с уважение към продукта и с прецизност, която сме научили от истинските майстори на занаята.</p>' }}
        </div>

        <a href="{{ menu_url }}" class="rab__cta rab__cta--ghost-dark">
          <span class="rab__cta-label">{{ section.settings.story_cta_label | default: 'ВИЖ МЕНЮТО' }}</span>
          <span class="rab__cta-arrow" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  {%- comment -%} ============ Philosophy (dark) ============ {%- endcomment -%}
  <section class="rab__values">
    <div class="rab__section-head">
      <div class="rab__eyebrow rab__eyebrow--light">
        <span class="rab__eyebrow-line"></span>
        <span class="rab__eyebrow-diamond">◇</span>
        <span class="rab__eyebrow-text">{{ section.settings.values_eyebrow | default: 'НАШАТА ФИЛОСОФИЯ' }}</span>
        <span class="rab__eyebrow-diamond">◇</span>
        <span class="rab__eyebrow-line"></span>
      </div>
      <h2 class="rab__section-title rab__section-title--light">{{ section.settings.values_title | default: 'ТРИ ПРИНЦИПА' }}</h2>
    </div>

    <div class="rab__values-grid">
      {%- assign values = section.blocks | where: 'type', 'value' -%}
      {%- if values.size > 0 -%}
        {%- for block in values -%}
          <article class="rab__value-card" {{ block.shopify_attributes }}>
            <span class="rab__value-num">{{ block.settings.number | default: forloop.index | prepend: '0' | slice: -2, 2 }}</span>
            <h3 class="rab__value-title">{{ block.settings.title }}</h3>
            <p class="rab__value-text">{{ block.settings.text }}</p>
            <span class="rab__value-diamond" aria-hidden="true">◇</span>
          </article>
        {%- endfor -%}
      {%- else -%}
        <article class="rab__value-card">
          <span class="rab__value-num">01</span>
          <h3 class="rab__value-title">Свежи съставки</h3>
          <p class="rab__value-text">Рибата идва ежедневно. Зеленчуците — от локални производители. Без компромиси.</p>
          <span class="rab__value-diamond" aria-hidden="true">◇</span>
        </article>
        <article class="rab__value-card">
          <span class="rab__value-num">02</span>
          <h3 class="rab__value-title">Майстори в занаята</h3>
          <p class="rab__value-text">Готвачите ни се обучават години, за да достигнат прецизността на японското суши.</p>
          <span class="rab__value-diamond" aria-hidden="true">◇</span>
        </article>
        <article class="rab__value-card">
          <span class="rab__value-num">03</span>
          <h3 class="rab__value-title">Уют &amp; гостоприемство</h3>
          <p class="rab__value-text">От топлото посрещане до последната хапка — всеки детайл е обмислен.</p>
          <span class="rab__value-diamond" aria-hidden="true">◇</span>
        </article>
      {%- endif -%}
    </div>
  </section>

  {%- comment -%} ============ Stats (white) ============ {%- endcomment -%}
  <section class="rab__stats">
    <div class="rab__stats-inner">
      {%- assign stats = section.blocks | where: 'type', 'stat' -%}
      {%- if stats.size > 0 -%}
        {%- for block in stats -%}
          <div class="rab__stat" {{ block.shopify_attributes }}>
            <span class="rab__stat-number">{{ block.settings.number }}</span>
            <span class="rab__stat-label">{{ block.settings.label }}</span>
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="rab__stat">
          <span class="rab__stat-number">12+</span>
          <span class="rab__stat-label">години опит</span>
        </div>
        <div class="rab__stat">
          <span class="rab__stat-number">120</span>
          <span class="rab__stat-label">ястия в менюто</span>
        </div>
        <div class="rab__stat">
          <span class="rab__stat-number">50k+</span>
          <span class="rab__stat-label">щастливи клиенти</span>
        </div>
        <div class="rab__stat">
          <span class="rab__stat-number">4.9</span>
          <span class="rab__stat-label">средна оценка</span>
        </div>
      {%- endif -%}
    </div>
  </section>

  {%- comment -%} ============ Chef (dark) ============ {%- endcomment -%}
  <section class="rab__chef">
    <div class="rab__chef-grid">
      <div class="rab__chef-media">
        {%- if section.settings.chef_image != blank -%}
          {{ section.settings.chef_image
            | image_url: width: 1400
            | image_tag:
              class: 'rab__chef-image',
              sizes: '(min-width: 990px) 50vw, 100vw',
              widths: '500,800,1100,1400',
              loading: 'lazy'
          }}
        {%- endif -%}
      </div>

      <div class="rab__chef-body">
        <div class="rab__eyebrow rab__eyebrow--light">
          <span class="rab__eyebrow-diamond">◇</span>
          <span class="rab__eyebrow-text">{{ section.settings.chef_eyebrow | default: 'НАШИЯТ ГОТВАЧ' }}</span>
          <span class="rab__eyebrow-diamond">◇</span>
        </div>

        <blockquote class="rab__chef-quote">
          <span class="rab__chef-quote-mark">"</span>
          {{ section.settings.chef_quote | default: 'Сушито не е просто храна — то е разказ. И всеки път, когато режа парче риба, мисля за човека, който ще го опита.' }}
        </blockquote>

        <div class="rab__chef-signature">
          <span class="rab__chef-name">{{ section.settings.chef_name | default: 'ШЕФ КОДЗИ ТАНАКА' }}</span>
          <span class="rab__chef-role">{{ section.settings.chef_role | default: 'Главен суши майстор' }}</span>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ============ CTA Banner ============ {%- endcomment -%}
  <section class="rab__cta-banner">
    {%- if section.settings.banner_image != blank -%}
      {{ section.settings.banner_image
        | image_url: width: 2400
        | image_tag:
          class: 'rab__cta-banner-image',
          sizes: '100vw',
          widths: '800,1200,1600,2400',
          loading: 'lazy'
      }}
    {%- endif -%}
    <div class="rab__cta-banner-overlay"></div>
    <div class="rab__cta-banner-content">
      <div class="rab__eyebrow rab__eyebrow--light">
        <span class="rab__eyebrow-diamond">◇</span>
        <span class="rab__eyebrow-text">{{ section.settings.banner_eyebrow | default: 'ЗАПОВЯДАЙ' }}</span>
        <span class="rab__eyebrow-diamond">◇</span>
      </div>
      <h2 class="rab__cta-banner-title">{{ section.settings.banner_title | default: 'СЪЗДАДЕНО С ЛЮБОВ. ПОДАДЕНО С УВАЖЕНИЕ.' }}</h2>
      <div class="rab__cta-banner-actions">
        <a href="{{ menu_url }}" class="rab__cta rab__cta--solid">
          <span class="rab__cta-label">{{ section.settings.banner_cta_primary | default: 'ВИЖ МЕНЮТО' }}</span>
          <span class="rab__cta-arrow" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
        <a href="{{ contact_url }}" class="rab__cta rab__cta--ghost-light">
          <span class="rab__cta-label">{{ section.settings.banner_cta_secondary | default: 'РЕЗЕРВИРАЙ МАСА' }}</span>
          <span class="rab__cta-arrow" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>
</div>

