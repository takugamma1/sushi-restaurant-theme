{%- liquid
  assign is_menu_page = false
  if template.suffix == 'menu' or request.path contains '/pages/menu'
    assign is_menu_page = true
  endif
-%}

<restaurant-menu-component
  class="restaurant-menu color-{{ section.settings.color_scheme }}"
  data-is-menu-page="{{ is_menu_page }}"
  style="
    --rm-heading-size: {{ section.settings.heading_size }}px;
    --rm-subheading-size: {{ section.settings.subheading_size }}px;
    --rm-item-title-size: {{ section.settings.item_title_size }}px;
    --rm-item-desc-size: {{ section.settings.item_desc_size }}px;
    --rm-price-size: {{ section.settings.price_size }}px;
    --rm-tab-size: {{ section.settings.tab_size }}px;
    --rm-category-border-radius: {{ section.settings.category_border_radius }}px;
    --rm-category-border-width: {{ section.settings.category_border_width }}px;
  "
>
  <div class="restaurant-menu__hero">
    {%- if section.settings.hero_image != blank -%}
      <img
        class="restaurant-menu__hero-image"
        id="rm-hero-image"
        src="{{ section.settings.hero_image | image_url: width: 1200 }}"
        data-default-src="{{ section.settings.hero_image | image_url: width: 1200 }}"
        alt="{{ section.settings.hero_image.alt | escape }}"
        width="{{ section.settings.hero_image.width }}"
        height="{{ section.settings.hero_image.height }}"
        loading="eager"
      >
    {%- else -%}
      <div class="restaurant-menu__hero-image" id="rm-hero-image" data-default-src="" style="background: #1a1a1a;"></div>
    {%- endif -%}
    <div class="restaurant-menu__hero-overlay">
      <p class="restaurant-menu__hero-sub">{{ section.settings.hero_subheading }}</p>
      <h1 class="restaurant-menu__hero-title">{{ section.settings.hero_heading }}</h1>
    </div>
  </div>

  <div class="restaurant-menu__content">
    {%- comment -%} Category tabs {%- endcomment -%}
    {%- if section.blocks.size > 1 -%}
      <div class="rm-tabs" ref="tabs">
        {%- assign tab_idx = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'category' -%}
            <button
              class="rm-tab{% if tab_idx == 0 %} rm-tab--active{% endif %}"
              data-tab="{{ tab_idx }}"
              type="button"
            >{{ block.settings.tab_label | default: block.settings.title }}</button>
            {%- assign tab_idx = tab_idx | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} Category panels {%- endcomment -%}
    {%- assign panel_idx = 0 -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'category' -%}
        {%- assign collection = block.settings.collection -%}
        <div
          class="rm-panel{% if panel_idx == 0 %} rm-panel--active{% endif %}"
          data-panel="{{ panel_idx }}"
          {{ block.shopify_attributes }}
        >
          {%- if collection != blank -%}
          <div class="rm-category-wrapper">
            {%- comment -%} Decorated category heading {%- endcomment -%}
            <div class="rm-cat-heading">
              <span class="rm-cat-heading__line"></span>
              <span class="rm-cat-heading__diamond">◇</span>
              <span class="rm-cat-heading__text">{{ block.settings.title | default: collection.title | upcase }}</span>
              <span class="rm-cat-heading__diamond">◇</span>
              <span class="rm-cat-heading__line"></span>
            </div>

            {%- comment -%} Product items {%- endcomment -%}
            {%- for product in collection.products limit: block.settings.max_products -%}
              <div
                class="rm-item{% if product.compare_at_price > product.price %} rm-item--sale{% endif %}"
                data-product-modal-trigger
                data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                data-product-title="{{ product.title | escape }}"
                data-product-desc="{{ product.description | strip_html | truncate: 150 | escape }}"
                data-product-price="{{ product.price }}"
                data-product-price-formatted="{{ product.price | money }}"
                data-product-image="{% if product.featured_image != blank %}{{ product.featured_image | image_url: width: 1200 }}{% endif %}"
              >
                <div class="rm-item__thumb">
                  {%- if product.featured_image != blank -%}
                    <img
                      src="{{ product.featured_image | image_url: width: 120, height: 120, crop: 'center' }}"
                      alt="{{ product.featured_image.alt | escape }}"
                      width="56"
                      height="56"
                      loading="lazy"
                    >
                  {%- else -%}
                    <div class="rm-item__thumb-placeholder"></div>
                  {%- endif -%}
                </div>

                <div class="rm-item__info">
                  <div class="rm-item__name">
                    {{ product.title }}
                    {%- if product.metafields.custom.spicy -%}
                      <span class="rm-item__icon" aria-label="Spicy">🌶️</span>
                    {%- endif -%}
                    {%- if product.metafields.custom.vegan -%}
                      <span class="rm-item__icon" aria-label="Vegan">🌿</span>
                    {%- endif -%}
                  </div>
                  <div class="rm-item__desc">
                    {{ product.description | strip_html | truncate: 100 }}
                  </div>
                </div>

                <div class="rm-item__price-col">
                  {%- if product.compare_at_price > product.price -%}
                    <span class="rm-item__price--old">{{ product.compare_at_price | money }}</span>
                  {%- endif -%}
                  <span class="rm-item__price">{{ product.price | money }}</span>
                  {%- if product.compare_at_price > product.price -%}
                    <span class="rm-item__badge">{{ block.settings.sale_badge_text | default: 'Най-продаван' }}</span>
                  {%- endif -%}
                </div>

                {%- comment -%} Add button for menu page only {%- endcomment -%}
                {%- if is_menu_page -%}
                  <button type="button" class="rm-item__add-btn" aria-label="Add {{ product.title }}">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <line x1="12" y1="5" x2="12" y2="19"></line>
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                  </button>
                {%- endif -%}
              </div>
            {%- endfor -%}

            {%- comment -%} CTA button inside category wrapper {%- endcomment -%}
            {%- if section.settings.cta_label != blank -%}
              <div class="rm-cta-wrap">
                <a href="{{ section.settings.cta_link | default: '#' }}" class="rm-cta">
                  {{ section.settings.cta_label }}
                </a>
              </div>
            {%- endif -%}
          </div>
          {%- endif -%}
        </div>
        {%- assign panel_idx = panel_idx | plus: 1 -%}
      {%- endif -%}
    {%- endfor -%}
  </div>
</restaurant-menu-component>

{%- comment -%} Product modal {%- endcomment -%}
{% render 'restaurant-product-modal',
  addons_collection: section.settings.addons_collection,
  sauces_collection: section.settings.sauces_collection,
  menu_page_url: section.settings.menu_page_url
%}

<script>
(function() {
  function initMenuHover() {
    const heroImage = document.querySelector('img.restaurant-menu__hero-image');
    if (!heroImage) {
      console.log('No hero image found');
      return;
    }
    const defaultHeroSrc = heroImage.getAttribute('src') || heroImage.src;
    const isDesktop = window.innerWidth >= 750;

    console.log('Menu init - Hero:', heroImage, 'Default src:', defaultHeroSrc, 'Desktop:', isDesktop);

  // Tab switching
  const tabs = document.querySelectorAll('.rm-tab');
  const panels = document.querySelectorAll('.rm-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', function() {
      const tabIndex = this.dataset.tab;

      tabs.forEach(t => t.classList.remove('rm-tab--active'));
      panels.forEach(p => p.classList.remove('rm-panel--active'));

      this.classList.add('rm-tab--active');
      document.querySelector(`[data-panel="${tabIndex}"]`)?.classList.add('rm-panel--active');
    });
  });

  // Product modal triggers
  const productItems = document.querySelectorAll('[data-product-modal-trigger]');

  productItems.forEach(item => {
    item.addEventListener('click', function(e) {
      // Prevent if clicking the add button directly
      if (e.target.closest('.rm-item__add-btn')) {
        e.stopPropagation();
      }

      const productData = {
        variantId: this.dataset.variantId,
        title: this.dataset.productTitle,
        description: this.dataset.productDesc,
        price: this.dataset.productPrice,
        priceFormatted: this.dataset.productPriceFormatted,
        image: this.dataset.productImage
      };

      if (window.restaurantModal) {
        window.restaurantModal.open(productData);
      }
    });

    // Hero image swap on hover (desktop only)
    if (isDesktop && heroImage) {
      item.addEventListener('mouseenter', function() {
        let productImage = this.getAttribute('data-product-image');
        if (productImage && productImage.startsWith('//')) {
          productImage = 'https:' + productImage;
        }
        console.log('Hover - Product image:', productImage);
        if (productImage && productImage.length > 0) {
          heroImage.src = productImage;
        }
      });

      item.addEventListener('mouseleave', function() {
        console.log('Leave - Restore to:', defaultHeroSrc);
        if (defaultHeroSrc && defaultHeroSrc.length > 0) {
          heroImage.src = defaultHeroSrc;
        }
      });
    }
  });
  }

  // Run when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMenuHover);
  } else {
    initMenuHover();
  }
})();
</script>

{% stylesheet %}
  .restaurant-menu-section {
    margin: 0;
    padding: 0;
  }

  restaurant-menu-component {
    display: grid;
    grid-template-columns: 1fr;
    background: var(--restaurant-dark, #0D0D0D);
    color: #fff;
  }

  @media (min-width: 750px) {
    restaurant-menu-component {
      grid-template-columns: 42% 1fr;
    }
  }

  .restaurant-menu__hero {
    position: relative;
    overflow: hidden;
    min-height: 40vh;
  }

  @media (min-width: 750px) {
    .restaurant-menu__hero {
      position: sticky;
      top: 0;
      height: 100vh;
    }
  }

  .restaurant-menu__hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    inset: 0;
    transition: opacity 0.15s ease;
  }

  .restaurant-menu__hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.15) 50%, transparent 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 2rem;
  }

  .restaurant-menu__hero-sub {
    font-family: var(--font-body--family);
    font-style: italic;
    font-size: var(--rm-subheading-size, 16px);
    color: rgba(255,255,255,0.75);
    margin-bottom: 0.25em;
  }

  .restaurant-menu__hero-title {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: var(--rm-heading-size, 48px);
    line-height: 1.05;
    color: #fff;
    text-transform: uppercase;
  }

  .restaurant-menu__content {
    padding: 2rem 2.5rem;
    overflow-y: auto;
  }

  /* Category tabs */
  .rm-tabs {
    display: flex;
    gap: 6px;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .rm-tab {
    font-size: var(--rm-tab-size, 11px);
    font-family: var(--font-body--family);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    background: transparent;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 4px;
    padding: 6px 14px;
    cursor: pointer;
    transition: color 0.3s ease, border-color 0.3s ease, background 0.3s ease;
    white-space: nowrap;
  }

  .rm-tab:hover {
    color: rgba(255,255,255,0.8);
    border-color: rgba(255,255,255,0.3);
  }

  .rm-tab--active {
    color: var(--restaurant-accent, #F98760);
    border-color: var(--restaurant-accent, #F98760);
    background: rgba(249, 135, 96, 0.08);
  }

  /* Panels */
  .rm-panel {
    display: none;
  }

  .rm-panel--active {
    display: block;
  }

  /* Category wrapper with border */
  .rm-category-wrapper {
    border: var(--rm-category-border-width, 2px) solid #F98760;
    border-radius: var(--rm-category-border-radius, 16px);
    padding: 1.5rem;
    margin-bottom: 1rem;
  }

  /* Category heading */
  .rm-cat-heading {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5em;
    margin-bottom: 1.5rem;
  }

  .rm-cat-heading__text {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: var(--rm-item-title-size, 14px);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--restaurant-accent, #F98760);
    white-space: nowrap;
  }

  .rm-cat-heading__line {
    display: inline-block;
    width: 30px;
    height: 1px;
    background: var(--restaurant-accent, #F98760);
    flex-shrink: 0;
  }

  .rm-cat-heading__diamond {
    font-size: 0.5em;
    color: var(--restaurant-accent, #F98760);
    flex-shrink: 0;
  }

  /* Menu item row */
  .rm-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    cursor: pointer;
    transition: background 0.25s ease;
    border-radius: 8px;
  }

  .rm-item:last-child {
    border-bottom: none;
  }

  .rm-item:hover {
    background: rgba(255,255,255,0.03);
  }

  .rm-item--sale {
    background: rgba(249, 135, 96, 0.06);
    border: 1px solid rgba(249, 135, 96, 0.15);
    padding: 0.75rem 0.75rem;
    margin-bottom: 4px;
  }

  /* Rounded thumbnail */
  .rm-item__thumb {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .rm-item__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 12px;
  }

  .rm-item__thumb-placeholder {
    width: 100%;
    height: 100%;
    background: #2a2a2a;
    border-radius: 12px;
  }

  /* Item info */
  .rm-item__info {
    flex: 1;
    min-width: 0;
  }

  .rm-item__name {
    font-family: var(--font-body--family);
    font-size: var(--rm-item-title-size, 14px);
    font-weight: 600;
    color: #fff;
    margin-bottom: 3px;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .rm-item__icon {
    font-size: 0.85em;
    flex-shrink: 0;
  }

  .rm-item__desc {
    font-size: var(--rm-item-desc-size, 12px);
    color: rgba(255,255,255,0.45);
    line-height: 1.4;
  }

  /* Price column */
  .rm-item__price-col {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 3px;
    flex-shrink: 0;
  }

  .rm-item__price {
    font-size: var(--rm-price-size, 14px);
    font-weight: 600;
    color: #fff;
  }

  .rm-item__price--old {
    font-size: calc(var(--rm-price-size, 14px) - 2px);
    text-decoration: line-through;
    color: rgba(255,255,255,0.4);
  }

  .rm-item__badge {
    background: var(--restaurant-accent, #F98760);
    color: #fff;
    font-size: 9px;
    padding: 2px 8px;
    border-radius: 10px;
    white-space: nowrap;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  /* CTA inside category wrapper */
  .rm-cta-wrap {
    display: flex;
    justify-content: center;
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(249, 135, 96, 0.3);
  }

  .rm-cta {
    display: inline-block;
    color: var(--restaurant-accent, #F98760);
    border: 1px solid var(--restaurant-accent, #F98760);
    background: transparent;
    padding: 0.7em 2.5em;
    font-family: var(--font-body--family);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 4px;
    transition: background 0.35s ease, color 0.35s ease;
  }

  .rm-cta:hover {
    background: var(--restaurant-accent, #F98760);
    color: #fff;
  }

  /* Add button for menu page */
  .rm-item__add-btn {
    width: 36px;
    height: 36px;
    border: none;
    background: transparent;
    color: var(--restaurant-accent, #F98760);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
    transition: all 0.25s ease;
    margin-left: 0.5rem;
    padding: 0;
  }

  .rm-item__add-btn:hover {
    color: #fff;
    transform: scale(1.15);
  }

  .rm-item__add-btn svg {
    width: 22px;
    height: 22px;
  }

  /* Make items look clickable */
  .rm-item {
    position: relative;
  }

  .rm-item::after {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: 10px;
    border: 2px solid transparent;
    transition: border-color 0.25s ease;
    pointer-events: none;
  }

  .rm-item:hover::after {
    border-color: rgba(249, 135, 96, 0.3);
  }
{% endstylesheet %}

{% schema %}
