{% liquid
  assign slide_count = 0
  assign slide_count_with_media = 0
  for block in section.blocks
    if block.type == 'slide'
      assign slide_count = slide_count | plus: 1
      assign has_media = false
      if block.settings.media_type == 'video' and block.settings.video != blank
        assign has_media = true
      elsif block.settings.image != blank
        assign has_media = true
      endif
      if has_media
        assign slide_count_with_media = slide_count_with_media | plus: 1
      endif
    endif
  endfor

  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif
%}

<restaurant-hero-carousel
  class="restaurant-hero color-{{ section.settings.color_scheme }}"
  data-autoplay="{{ section.settings.autoplay }}"
  data-interval="{{ section.settings.autoplay_interval }}"
  style="
    {% if section.settings.section_height == 'custom' %}
      --restaurant-hero-height: {{ section.settings.section_height_custom }}svh;
    {% else %}
      --restaurant-hero-height: 100svh;
    {% endif %}
  "
>
  {%- comment -%} Slides {%- endcomment -%}
  <div class="restaurant-hero__slides" ref="slides">
    {%- assign slide_index = 0 -%}
    {%- assign media_slide_index = 0 -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'slide' -%}
        {%- liquid
          assign slide_has_media = false
          if block.settings.media_type == 'video' and block.settings.video != blank
            assign slide_has_media = true
          elsif block.settings.image != blank
            assign slide_has_media = true
          endif
        -%}
        {%- if slide_has_media -%}
          <div
            class="restaurant-hero__slide{% if media_slide_index == 0 %} restaurant-hero__slide--active{% endif %}"
            data-slide-index="{{ media_slide_index }}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.media_type == 'video' and block.settings.video != blank -%}
              {{ block.settings.video
                | video_tag:
                  poster: nil,
                  autoplay: true,
                  loop: true,
                  controls: false,
                  muted: true,
                  class: 'restaurant-hero__media'
              }}
            {%- elsif block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 3840
                | image_tag:
                  width: block.settings.image.width,
                  widths: '832, 1200, 1600, 1920, 2560, 3840',
                  height: block.settings.image.height,
                  alt: block.settings.image.alt,
                  class: 'restaurant-hero__media',
                  sizes: '100vw',
                  fetchpriority: fetch_priority
              }}
            {%- endif -%}
          </div>
          {%- assign media_slide_index = media_slide_index | plus: 1 -%}
        {%- endif -%}
        {%- assign slide_index = slide_index | plus: 1 -%}
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- comment -%} Overlay {%- endcomment -%}
  {%- if section.settings.toggle_overlay -%}
    <div
      class="restaurant-hero__overlay"
      style="background: {{ section.settings.overlay_color }};"
    ></div>
  {%- endif -%}

  {%- comment -%} Content {%- endcomment -%}
  <div class="restaurant-hero__content">
    {%- if section.settings.subheading != blank -%}
      <p class="restaurant-hero__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h1 class="restaurant-hero__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link | default: '/pages/menu' }}" class="restaurant-nav__cta restaurant-hero__cta">
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>

  {%- comment -%} Vertical dot navigation {%- endcomment -%}
  {%- if slide_count_with_media > 1 -%}
    <nav class="restaurant-hero__dots" ref="dots" aria-label="Slide navigation">
      {%- for i in (0..slide_count_with_media) -%}
        {%- if i < slide_count_with_media -%}
          <button
            class="restaurant-hero__dot{% if i == 0 %} restaurant-hero__dot--active{% endif %}"
            data-dot-index="{{ i }}"
            aria-label="Go to slide {{ i | plus: 1 }}"
            type="button"
          ></button>
        {%- endif -%}
      {%- endfor -%}
    </nav>
  {%- endif -%}
</restaurant-hero-carousel>

<script
  src="{{ 'restaurant-hero.js' | asset_url }}"
  type="module"
></script>

{% stylesheet %}
  restaurant-hero-carousel {
    display: block;
    position: relative;
    min-height: var(--restaurant-hero-height, 100svh);
    overflow: hidden;
  }

  .restaurant-hero__slides {
    position: absolute;
    inset: 0;
  }

  .restaurant-hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1.2s cubic-bezier(0.25, 0.1, 0.25, 1);
    z-index: 0;
  }

  .restaurant-hero__slide--active {
    opacity: 1;
    z-index: 1;
  }

  .restaurant-hero__media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .restaurant-hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
  }

  .restaurant-hero__content {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: var(--restaurant-hero-height, 100svh);
    padding: var(--padding-2xl);
    pointer-events: none;
  }

  .restaurant-hero__content > * {
    pointer-events: auto;
  }

  .restaurant-hero__subheading {
    font-family: var(--font-body--family);
    font-style: italic;
    font-size: clamp(0.875rem, 1.5vw, 1.125rem);
    color: #ffffffcc;
    margin-bottom: var(--margin-xs);
    letter-spacing: 0.02em;
  }

  .restaurant-hero__heading {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: clamp(2.5rem, 6vw, 5rem);
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.05;
    margin-bottom: var(--margin-lg);
    max-width: 14ch;
  }

  .restaurant-hero__cta {
    margin-top: var(--margin-sm);
  }

  /* Vertical dots */
  .restaurant-hero__dots {
    position: absolute;
    right: var(--padding-xl);
    top: 50%;
    transform: translateY(-50%);
    z-index: 4;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .restaurant-hero__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1.5px solid rgba(255, 255, 255, 0.5);
    background: transparent;
    padding: 0;
    cursor: pointer;
    transition: background 0.4s ease, border-color 0.4s ease, transform 0.4s ease;
  }

  .restaurant-hero__dot:hover {
    border-color: #fff;
    transform: scale(1.3);
  }

  .restaurant-hero__dot--active {
    background: #fff;
    border-color: #fff;
  }

  @media screen and (max-width: 749px) {
    .restaurant-hero__dots {
      right: var(--padding-md);
      gap: 10px;
    }

    .restaurant-hero__dot {
      width: 6px;
      height: 6px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Restaurant Hero",
  "tag": "section",
  "class": "hero-wrapper section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Най-доброто суши в града"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "СУШИ БАР МАНГО"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "ПОРЪЧАЙ СЕГА"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "default": "/pages/menu"
    },
    {
      "type": "header",
      "content": "Carousel"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay slides",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_interval",
      "label": "Slide interval (seconds)",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 6,
      "unit": "s"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Height",
      "options": [
        {
          "value": "full-screen",
          "label": "Full screen"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "full-screen"
    },
    {
      "type": "range",
      "id": "section_height_custom",
      "label": "Custom height",
      "min": 30,
      "max": 100,
      "step": 5,
      "default": 80,
      "unit": "%",
      "visible_if": "{{ section.settings.section_height == 'custom' }}"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-5"
    },
    {
      "type": "checkbox",
      "id": "toggle_overlay",
      "label": "Media overlay",
      "default": true
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "alpha": true,
      "default": "#00000050",
      "visible_if": "{{ section.settings.toggle_overlay }}"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "select",
          "id": "media_type",
          "label": "Media type",
          "options": [
            {
              "value": "image",
              "label": "Image"
            },
            {
              "value": "video",
              "label": "Video"
            }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "visible_if": "{{ block.settings.media_type == 'image' }}"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "visible_if": "{{ block.settings.media_type == 'video' }}"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Restaurant Hero",
      "category": "Custom",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ],
      "settings": {
        "subheading": "Най-доброто суши в града",
        "heading": "СУШИ БАР МАНГО",
        "button_label": "ПОРЪЧАЙ СЕГА",
        "autoplay": true,
        "autoplay_interval": 6,
        "section_height": "full-screen",
        "color_scheme": "scheme-5",
        "toggle_overlay": true,
        "overlay_color": "#00000050"
      }
    }
  ]
}
{% endschema %}
