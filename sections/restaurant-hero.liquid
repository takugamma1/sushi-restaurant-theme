{%- liquid
  assign total_slides = 0
  for block in section.blocks
    if block.type == 'slide'
      assign has_media = false
      if block.settings.media_type == 'video' and block.settings.video != blank
        assign has_media = true
      elsif block.settings.image != blank
        assign has_media = true
      endif
      if has_media
        assign total_slides = total_slides | plus: 1
      endif
    endif
  endfor

  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif
-%}

<restaurant-hero
  class="rh color-{{ section.settings.color_scheme }}"
  {% if total_slides > 1 and section.settings.autoplay %}
    data-autoplay="{{ section.settings.autoplay_interval }}"
  {% endif %}
  style="--rh-height: {% if section.settings.height == 'custom' %}{{ section.settings.height_custom }}svh{% else %}100svh{% endif %};"
>
  <div class="rh__slides">
    {%- assign idx = 0 -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'slide' -%}
        {%- liquid
          assign has_media = false
          if block.settings.media_type == 'video' and block.settings.video != blank
            assign has_media = true
          elsif block.settings.image != blank
            assign has_media = true
          endif
        -%}
        {%- if has_media -%}
          <div
            class="rh__slide{% if idx == 0 %} is-active{% endif %}"
            data-index="{{ idx }}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.media_type == 'video' and block.settings.video != blank -%}
              {{ block.settings.video
                | video_tag:
                  poster: nil,
                  autoplay: true,
                  loop: true,
                  controls: false,
                  muted: true,
                  class: 'rh__media'
              }}
            {%- else -%}
              {{ block.settings.image
                | image_url: width: 3840
                | image_tag:
                  width: block.settings.image.width,
                  widths: '832,1200,1600,1920,2560,3840',
                  height: block.settings.image.height,
                  alt: block.settings.image.alt,
                  class: 'rh__media',
                  sizes: '100vw',
                  fetchpriority: fetch_priority
              }}
            {%- endif -%}
          </div>
          {%- assign idx = idx | plus: 1 -%}
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- if section.settings.overlay -%}
    <div class="rh__overlay" style="background:{{ section.settings.overlay_color }};"></div>
  {%- endif -%}

  <div class="rh__content">
    {%- if section.settings.subheading != blank -%}
      <p class="rh__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h1 class="rh__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.settings.cta_label != blank -%}
      <a href="{{ section.settings.cta_link | default: '#' }}" class="rh__cta">
        {{ section.settings.cta_label }}
      </a>
    {%- endif -%}
  </div>

  {%- if total_slides > 1 -%}
    <nav class="rh__dots" aria-label="Slides">
      {%- for i in (1..total_slides) -%}
        <button
          class="rh__dot{% if forloop.first %} is-active{% endif %}"
          data-dot="{{ forloop.index0 }}"
          aria-label="Slide {{ forloop.index }}"
          type="button"
        ></button>
      {%- endfor -%}
    </nav>
  {%- endif -%}
</restaurant-hero>

<script src="{{ 'restaurant-hero.js' | asset_url }}" type="module"></script>

{% stylesheet %}
  restaurant-hero {
    display: block;
    position: relative;
    min-height: var(--rh-height, 100svh);
    overflow: hidden;
    background: #0d0d0d;
  }

  .rh__slides {
    position: absolute;
    inset: 0;
  }

  .rh__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1.4s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: opacity;
  }

  .rh__slide.is-active {
    opacity: 1;
    z-index: 1;
  }

  .rh__media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .rh__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
  }

  .rh__content {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: var(--rh-height, 100svh);
    padding: var(--padding-2xl);
    pointer-events: none;
  }

  .rh__content > * {
    pointer-events: auto;
  }

  .rh__sub {
    font-family: var(--font-body--family);
    font-style: italic;
    font-size: clamp(0.875rem, 1.5vw, 1.125rem);
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 0.5em;
    letter-spacing: 0.02em;
  }

  .rh__heading {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: clamp(2.5rem, 6vw, 5rem);
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.05;
    margin-bottom: 0.6em;
    max-width: 14ch;
  }

  .rh__cta {
    display: inline-block;
    color: var(--restaurant-accent, #F98760);
    border: 1px solid var(--restaurant-accent, #F98760);
    background: transparent;
    padding: 0.65em 1.6em;
    font-family: var(--font-body--family);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.35s ease, color 0.35s ease;
  }

  .rh__cta:hover {
    background: var(--restaurant-accent, #F98760);
    color: #fff;
  }

  .rh__dots {
    position: absolute;
    right: clamp(1rem, 3vw, 2.5rem);
    top: 50%;
    transform: translateY(-50%);
    z-index: 4;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .rh__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1.5px solid rgba(255, 255, 255, 0.45);
    background: transparent;
    padding: 0;
    cursor: pointer;
    transition: background 0.4s ease, border-color 0.4s ease, transform 0.4s ease;
  }

  .rh__dot:hover {
    border-color: rgba(255, 255, 255, 0.9);
    transform: scale(1.35);
  }

  .rh__dot.is-active {
    background: #fff;
    border-color: #fff;
  }

  @media (max-width: 749px) {
    .rh__dots {
      right: 0.75rem;
      gap: 10px;
    }
    .rh__dot {
      width: 6px;
      height: 6px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Restaurant Hero",
  "tag": "section",
  "class": "hero-wrapper section-wrapper",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Най-доброто суши в града"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "СУШИ БАР МАНГО"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "ПОРЪЧАЙ СЕГА"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link",
      "default": "/pages/menu"
    },
    {
      "type": "header",
      "content": "Carousel"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-rotate slides",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_interval",
      "label": "Seconds per slide",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 6,
      "unit": "s",
      "visible_if": "{{ section.settings.autoplay }}"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Height",
      "options": [
        { "value": "full", "label": "Full screen" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "full"
    },
    {
      "type": "range",
      "id": "height_custom",
      "label": "Custom height",
      "min": 30,
      "max": 100,
      "step": 5,
      "default": 80,
      "unit": "%",
      "visible_if": "{{ section.settings.height == 'custom' }}"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-5"
    },
    {
      "type": "checkbox",
      "id": "overlay",
      "label": "Media overlay",
      "default": true
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "alpha": true,
      "default": "#00000055",
      "visible_if": "{{ section.settings.overlay }}"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "select",
          "id": "media_type",
          "label": "Type",
          "options": [
            { "value": "image", "label": "Image" },
            { "value": "video", "label": "Video" }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "visible_if": "{{ block.settings.media_type == 'image' }}"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "visible_if": "{{ block.settings.media_type == 'video' }}"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Restaurant Hero",
      "category": "Custom",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
