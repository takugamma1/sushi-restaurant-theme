      "default": "РАБОТНО ВРЕМЕ"
    },
    {
      "type": "text",
      "id": "hours_mon",
      "label": "Monday",
      "default": "16:00 - 22:30"
    },
    {
      "type": "text",
      "id": "hours_tue",
      "label": "Tuesday",
      "default": "16:00 - 22:30"
    },
    {
      "type": "text",
      "id": "hours_wed",
      "label": "Wednesday",
      "default": "16:00 - 22:30"
    },
    {
      "type": "text",
      "id": "hours_thu",
      "label": "Thursday",
      "default": "16:00 - 22:30"
    },
    {
      "type": "text",
      "id": "hours_fri",
      "label": "Friday",
      "default": "16:00 - 22:30"
    },
    {
      "type": "text",
      "id": "hours_weekend",
      "label": "Sat & Sun",
      "default": "16:00 - 22:30"
    },
    {
      "type": "header",
      "content": "Map"
    },
    {
      "type": "text",
      "id": "map_address",
      "label": "Map address",
      "default": "23 Greenfield Avenue, Prague"
    },
    {
      "type": "url",
      "id": "map_link",
      "label": "Google Maps link"
    },
    {
      "type": "header",
      "content": "Contact Info"
    },
    {
      "type": "text",
      "id": "address",
      "label": "Address",
      "default": "23 Greenfield Avenue, Prague 120 00"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone",
      "default": "+49 1234 567890"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
